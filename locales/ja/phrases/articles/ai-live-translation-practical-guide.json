  "ai_live_translation.body": "<p>\u76f8\u624b\u306e\u8a00\u8449\u3092\u307b\u307c\u540c\u6642\u306b\u5225\u306e\u8a00\u8a9e\u3067\u805e\u3051\u308bAI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u306f\u3001\u65c5\u884c\u3060\u3051\u306e\u4fbf\u5229\u6a5f\u80fd\u3067\u306f\u306a\u304f\u306a\u308a\u307e\u3057\u305f\u3002\u6d77\u5916\u306e\u53d6\u5f15\u5148\u3068\u306e\u6253\u3061\u5408\u308f\u305b\u3001\u7559\u5b66\u751f\u3068\u306e\u5171\u540c\u4f5c\u696d\u3001\u30db\u30c6\u30eb\u3084\u75c5\u9662\u3067\u306e\u6848\u5185\u306a\u3069\u3001\u8a00\u8449\u306e\u58c1\u3067\u4f1a\u8a71\u3092\u8ae6\u3081\u3066\u3044\u305f\u5834\u9762\u306b\u9078\u629e\u80a2\u3092\u5897\u3084\u3057\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u7ffb\u8a33\u304c\u6ed1\u3089\u304b\u306b\u306a\u308b\u307b\u3069\u300c\u753b\u9762\u306b\u51fa\u305f\u304b\u3089\u6b63\u3057\u3044\u300d\u3068\u53d7\u3051\u53d6\u308a\u3084\u3059\u304f\u306a\u308a\u307e\u3059\u3002\u4eba\u540d\u3001\u91d1\u984d\u3001\u65e5\u6642\u3001\u540c\u610f\u3001\u4f53\u8abf\u306b\u95a2\u3059\u308b\u8868\u73fe\u306f\u3001\u305f\u3063\u305f\u4e00\u8a9e\u306e\u9055\u3044\u304c\u5927\u304d\u306a\u884c\u304d\u9055\u3044\u306b\u3064\u306a\u304c\u308a\u307e\u3059\u3002AI\u3092\u901a\u8a33\u306e\u4ee3\u7528\u54c1\u3068\u3057\u3066\u4e38\u6295\u3052\u3059\u308b\u306e\u3067\u306f\u306a\u304f\u3001\u76f8\u624b\u306e\u610f\u56f3\u3092\u78ba\u304b\u3081\u308b\u305f\u3081\u306e\u4f1a\u8a71\u306e\u88dc\u52a9\u8f2a\u3068\u3057\u3066\u4f7f\u3046\u3053\u3068\u304c\u3001\u4fbf\u5229\u3055\u3068\u4fe1\u983c\u3092\u4e21\u7acb\u3055\u305b\u308b\u51fa\u767a\u70b9\u3067\u3059\u3002</p><h3>\u7ffb\u8a33\u304c\u4f1a\u8a71\u306e\u9014\u4e2d\u306b\u5165\u308b\u6642\u4ee3</h3><p>Google\u306f2026\u5e747\u67081\u65e5\u30016\u6708\u306eAI\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\u3068\u3057\u3066Gemini 3.5 Live Translate\u3092\u7d39\u4ecb\u3057\u307e\u3057\u305f\u3002\u516c\u5f0f\u767a\u8868\u3067\u306f\u300170\u4ee5\u4e0a\u306e\u8a00\u8a9e\u3092\u81ea\u52d5\u691c\u51fa\u3057\u3001\u8a71\u3057\u624b\u306e\u81ea\u7136\u306a\u6291\u63da\u3092\u4fdd\u3061\u306a\u304c\u3089\u3001\u304e\u3053\u3061\u306a\u3044\u9593\u3092\u6e1b\u3089\u3059\u97f3\u58f0\u304b\u3089\u97f3\u58f0\u3078\u306e\u7ffb\u8a33\u3092\u63b2\u3052\u3066\u3044\u307e\u3059\u3002Gemini Live API\u3001Google AI Studio\u3001Google\u7ffb\u8a33\u30a2\u30d7\u30ea\u306b\u5c55\u958b\u3055\u308c\u308b\u4e88\u5b9a\u3067\u3059\u3002\u540c\u3058\u767a\u8868\u3067\u306fAndroid 17\u306e\u6a5f\u80fd\u3084\u30ce\u30fc\u30c8PC\u3067\u52d5\u304f\u30ed\u30fc\u30ab\u30eb\u30e2\u30c7\u30eb\u306b\u3082\u89e6\u308c\u3089\u308c\u307e\u3057\u305f\u3002\u5927\u5207\u306a\u306e\u306f\u88fd\u54c1\u540d\u3092\u8ffd\u3046\u3053\u3068\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u7ffb\u8a33\u304c\u300c\u6587\u7ae0\u3092\u30b3\u30d4\u30fc\u3057\u3066\u5f85\u3064\u4f5c\u696d\u300d\u304b\u3089\u3001\u4f1a\u8b70\u3084\u79fb\u52d5\u4e2d\u306e\u4f1a\u8a71\u306b\u5bc4\u308a\u6dfb\u3046\u6a5f\u80fd\u3078\u8fd1\u3065\u3044\u3066\u3044\u308b\u70b9\u3067\u3059\u3002\u5229\u7528\u3067\u304d\u308b\u5730\u57df\u30fb\u8a00\u8a9e\u30fb\u7aef\u672b\u306f\u5909\u308f\u308a\u5f97\u308b\u305f\u3081\u3001\u4f7f\u3046\u76f4\u524d\u306b\u516c\u5f0f\u306e\u63d0\u4f9b\u72b6\u6cc1\u3092\u78ba\u8a8d\u3057\u307e\u3057\u3087\u3046\u3002</p><h3>\u4f7f\u3044\u3053\u306a\u3059\u305f\u3081\u306e5\u3064\u306e\u30eb\u30fc\u30eb</h3><p><strong>1. \u76ee\u7684\u3092\u4e00\u6587\u306b\u3059\u308b\u3002</strong>\u4e88\u7d04\u5185\u5bb9\u3092\u78ba\u8a8d\u3059\u308b\u3001\u6b21\u306e\u62c5\u5f53\u3068\u7de0\u5207\u3092\u6c7a\u3081\u308b\u3001\u6388\u696d\u306e\u8cea\u554f\u3092\u3059\u308b\u3001\u3068\u6700\u521d\u306b\u6c7a\u3081\u307e\u3059\u3002<strong>2. \u56fa\u6709\u540d\u8a5e\u3068\u6570\u5b57\u3092\u6e96\u5099\u3059\u308b\u3002</strong>\u4eba\u540d\u3001\u5730\u540d\u3001\u7565\u8a9e\u3001\u91d1\u984d\u306f\u30e1\u30e2\u3067\u3082\u898b\u305b\u306a\u304c\u3089\u78ba\u8a8d\u3057\u307e\u3059\u3002<strong>3. \u4e00\u6587\u3092\u77ed\u304f\u3057\u3001\u8a00\u3044\u63db\u3048\u308b\u3002</strong>\u8fd4\u7b54\u304c\u51fa\u305f\u3089\u300c\u3064\u307e\u308a\u3001\u7de0\u5207\u306f\u706b\u66dc\u65e5\u306e\u5348\u5f8c3\u6642\u3067\u3059\u306d\u300d\u3068\u81ea\u5206\u306e\u8a00\u8449\u3067\u5fa9\u5531\u3057\u307e\u3059\u3002\u6163\u7528\u53e5\u3084\u76ae\u8089\u3001\u66d6\u6627\u306a\u4e3b\u8a9e\u306f\u907f\u3051\u3001\u901a\u3058\u306a\u3051\u308c\u3070\u4e3b\u8a9e\u3092\u8db3\u3057\u3066\u5225\u306e\u8868\u73fe\u306b\u3057\u307e\u3059\u3002<strong>4. \u91cd\u8981\u4e8b\u9805\u306f\u6587\u5b57\u3067\u3082\u78ba\u5b9a\u3059\u308b\u3002</strong>\u5951\u7d04\u3001\u652f\u6255\u3044\u3001\u533b\u7642\u3001\u5b89\u5168\u3001\u63a1\u7528\u306b\u95a2\u308f\u308b\u5185\u5bb9\u306f\u3001\u91d1\u984d\u30fb\u901a\u8ca8\u30fb\u65e5\u4ed8\u30fb\u6761\u4ef6\u3092\u53cc\u65b9\u3067\u8aad\u307f\u4e0a\u3052\u3001\u66f8\u9762\u306b\u3082\u6b8b\u3057\u307e\u3059\u3002\u7ffb\u8a33\u6587\u306f\u8b70\u4e8b\u9332\u3067\u306f\u306a\u304f\u3001\u7406\u89e3\u3092\u5408\u308f\u305b\u308b\u305f\u3081\u306e\u4e0b\u66f8\u304d\u3067\u3059\u3002<strong>5. \u97f3\u58f0\u306e\u884c\u304d\u5148\u3092\u78ba\u8a8d\u3059\u308b\u3002</strong>\u7aef\u672b\u5185\u304b\u30b5\u30fc\u30d0\u30fc\u304b\u3001\u5c65\u6b74\u3084\u9332\u97f3\u304c\u6b8b\u308b\u304b\u3001\u5b66\u7fd2\u5229\u7528\u3092\u5909\u3048\u3089\u308c\u308b\u304b\u3092\u78ba\u8a8d\u3057\u307e\u3059\u3002\u516c\u958b\u306e\u5834\u3067\u306f\u30a4\u30e4\u30db\u30f3\u3092\u4f7f\u3044\u3001\u6a5f\u5bc6\u60c5\u5831\u306f\u7d44\u7e54\u3067\u8a31\u53ef\u3055\u308c\u305f\u30b5\u30fc\u30d3\u30b9\u3060\u3051\u3067\u6271\u3044\u307e\u3057\u3087\u3046\u3002</p><h3>\u5b8c\u74a7\u306a\u901a\u8a33\u3067\u306f\u306a\u304f\u3001\u5bfe\u8a71\u3092\u59cb\u3081\u308b\u305f\u3081\u306e\u9053\u5177</h3><p>\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u306e\u4fa1\u5024\u306f\u3001\u3059\u3079\u3066\u3092\u81ea\u52d5\u5316\u3059\u308b\u3053\u3068\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u8a00\u8449\u304c\u9055\u3046\u76f8\u624b\u306b\u3082\u3001\u307e\u305a\u8a71\u3057\u304b\u3051\u3001\u78ba\u304b\u3081\u3001\u3082\u3046\u4e00\u5ea6\u805e\u304f\u4f59\u767d\u3092\u3064\u304f\u308b\u3053\u3068\u3067\u3059\u3002\u76ee\u7684\u3092\u5148\u306b\u6c7a\u3081\u308b\u3001\u77ed\u304f\u8a71\u3059\u3001\u91cd\u8981\u4e8b\u9805\u306f\u5fa9\u5531\u3059\u308b\u3001\u97f3\u58f0\u30c7\u30fc\u30bf\u306e\u6271\u3044\u3092\u78ba\u8a8d\u3059\u308b\u3002\u3053\u306e\u7fd2\u6163\u304c\u3042\u308c\u3070\u3001\u65b0\u3057\u3044\u6a5f\u80fd\u304c\u767b\u5834\u3057\u3066\u3082\u632f\u308a\u56de\u3055\u308c\u306b\u304f\u304f\u306a\u308a\u307e\u3059\u3002\u7ffb\u8a33\u304c\u4e0d\u81ea\u7136\u3060\u3063\u305f\u77ac\u9593\u306f\u5931\u6557\u3067\u306f\u306a\u304f\u3001\u4f1a\u8a71\u3092\u4e01\u5be7\u306b\u3059\u308b\u5408\u56f3\u3067\u3059\u3002\u76f8\u624b\u3068\u4e00\u7dd2\u306b\u610f\u5473\u3092\u7d44\u307f\u7acb\u3066\u308b\u59ff\u52e2\u3053\u305d\u304c\u3001\u6280\u8853\u3092\u4eba\u306b\u5f79\u7acb\u3064\u3082\u306e\u306b\u5909\u3048\u307e\u3059\u3002</p><h3>\u53c2\u8003\u306b\u3057\u305f\u6700\u65b0\u60c5\u5831</h3><p><a href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-june-2026/\" target=\"_blank\" rel=\"noopener noreferrer\">Google\u516c\u5f0f\uff1a2026\u5e746\u6708\u306eAI\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8</a>\uff082026\u5e747\u67081\u65e5\u516c\u958b\uff09\u3002\u672c\u8a18\u4e8b\u306f\u540c\u767a\u8868\u306e\u6a5f\u80fd\u8aac\u660e\u3092\u8e0f\u307e\u3048\u3001\u5b9f\u969b\u306e\u4f1a\u8a71\u3067\u5f79\u7acb\u3064\u78ba\u8a8d\u3068\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u306e\u8003\u3048\u65b9\u3092\u72ec\u81ea\u306b\u6574\u7406\u3057\u305f\u3082\u306e\u3067\u3059\u3002</p>",
  "ai_live_translation.introduction": "\u76f8\u624b\u306e\u8a00\u8449\u3092\u307b\u307c\u540c\u6642\u306b\u5225\u306e\u8a00\u8a9e\u3067\u805e\u3051\u308b\u2015\u2015AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u306f\u3001\u65c5\u884c\u8005\u3060\u3051\u306e\u4fbf\u5229\u6a5f\u80fd\u3067\u306f\u306a\u304f\u306a\u308a\u307e\u3057\u305f\u3002\u6d77\u5916\u306e\u53d6\u5f15\u5148\u3068\u306e\u77ed\u3044\u6253\u3061\u5408\u308f\u305b\u3001\u7559\u5b66\u751f\u3068\u306e\u5171\u540c\u4f5c\u696d\u3001\u30db\u30c6\u30eb\u3084\u75c5\u9662\u3067\u306e\u6848\u5185\u306a\u3069\u3001\u8a00\u8449\u306e\u58c1\u3067\u4f1a\u8a71\u3092\u8ae6\u3081\u3066\u3044\u305f\u5834\u9762\u306b\u9078\u629e\u80a2\u3092\u5897\u3084\u3057\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u7ffb\u8a33\u304c\u6ed1\u3089\u304b\u306b\u306a\u308b\u307b\u3069\u300c\u753b\u9762\u306b\u51fa\u305f\u304b\u3089\u6b63\u3057\u3044\u300d\u3068\u53d7\u3051\u53d6\u308a\u3084\u3059\u304f\u306a\u308a\u307e\u3059\u3002\u4eba\u540d\u3001\u91d1\u984d\u3001\u65e5\u6642\u3001\u540c\u610f\u3001\u4f53\u8abf\u306b\u95a2\u3059\u308b\u8868\u73fe\u306f\u3001\u305f\u3063\u305f\u4e00\u8a9e\u306e\u9055\u3044\u304c\u5927\u304d\u306a\u884c\u304d\u9055\u3044\u306b\u3064\u306a\u304c\u308a\u307e\u3059\u3002AI\u3092\u901a\u8a33\u306e\u4ee3\u7528\u54c1\u3068\u3057\u3066\u4e38\u6295\u3052\u3059\u308b\u306e\u3067\u306f\u306a\u304f\u3001\u76f8\u624b\u306e\u610f\u56f3\u3092\u78ba\u304b\u3081\u308b\u305f\u3081\u306e\u4f1a\u8a71\u306e\u88dc\u52a9\u8f2a\u3068\u3057\u3066\u4f7f\u3046\u3002\u305d\u306e\u59ff\u52e2\u304c\u3001\u4fbf\u5229\u3055\u3068\u4fe1\u983c\u3092\u4e21\u7acb\u3055\u305b\u308b\u51fa\u767a\u70b9\u3067\u3059\u3002",
  "ai_live_translation.news_heading": "\u6700\u65b0\u30cb\u30e5\u30fc\u30b9\u304c\u793a\u3059\u306e\u306f\u300c\u7ffb\u8a33\u304c\u4f1a\u8a71\u306e\u9014\u4e2d\u306b\u5165\u308b\u300d\u5909\u5316",
  "ai_live_translation.news_body": "Google\u306f2026\u5e747\u67081\u65e5\u30016\u6708\u306eAI\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\u3068\u3057\u3066Gemini 3.5 Live Translate\u3092\u7d39\u4ecb\u3057\u307e\u3057\u305f\u3002\u516c\u5f0f\u767a\u8868\u3067\u306f\u300170\u4ee5\u4e0a\u306e\u8a00\u8a9e\u3092\u81ea\u52d5\u691c\u51fa\u3057\u3001\u8a71\u3057\u624b\u306e\u81ea\u7136\u306a\u6291\u63da\u3092\u4fdd\u3061\u306a\u304c\u3089\u3001\u304e\u3053\u3061\u306a\u3044\u9593\u3092\u6e1b\u3089\u3059\u97f3\u58f0\u304b\u3089\u97f3\u58f0\u3078\u306e\u7ffb\u8a33\u3092\u63b2\u3052\u3066\u3044\u307e\u3059\u3002Gemini Live API\u3001Google AI Studio\u3001Google\u7ffb\u8a33\u30a2\u30d7\u30ea\u306b\u5c55\u958b\u3055\u308c\u308b\u4e88\u5b9a\u3067\u3059\u3002\u540c\u3058\u767a\u8868\u3067\u306fAndroid 17\u306e\u6a5f\u80fd\u3084\u3001\u30ce\u30fc\u30c8PC\u3067\u52d5\u304f\u30ed\u30fc\u30ab\u30eb\u30e2\u30c7\u30eb\u306b\u3082\u89e6\u308c\u3089\u308c\u307e\u3057\u305f\u3002\u3053\u3053\u3067\u5927\u5207\u306a\u306e\u306f\u88fd\u54c1\u540d\u3092\u8ffd\u3046\u3053\u3068\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u7ffb\u8a33\u304c\u300c\u6587\u7ae0\u3092\u30b3\u30d4\u30fc\u3057\u3066\u5f85\u3064\u4f5c\u696d\u300d\u304b\u3089\u3001\u4f1a\u8b70\u3084\u79fb\u52d5\u4e2d\u306e\u4f1a\u8a71\u306b\u5bc4\u308a\u6dfb\u3046\u6a5f\u80fd\u3078\u8fd1\u3065\u3044\u3066\u3044\u308b\u70b9\u3067\u3059\u3002\u5229\u7528\u3067\u304d\u308b\u5730\u57df\u30fb\u8a00\u8a9e\u30fb\u7aef\u672b\u306f\u5909\u308f\u308a\u5f97\u308b\u305f\u3081\u3001\u4f7f\u3046\u76f4\u524d\u306b\u516c\u5f0f\u306e\u63d0\u4f9b\u72b6\u6cc1\u3092\u78ba\u8a8d\u3057\u307e\u3057\u3087\u3046\u3002",
  "ai_live_translation.prepare_heading": "\u59cb\u3081\u308b\u524d\u306b\u6c7a\u3081\u308b\u306e\u306f\u3001\u8a00\u8a9e\u3067\u306f\u306a\u304f\u4f1a\u8a71\u306e\u76ee\u7684",
  "ai_live_translation.prepare_body": "\u6700\u521d\u306b\u300c\u4eca\u65e5\u306f\u4f55\u3092\u6c7a\u3081\u308b\u4f1a\u8a71\u304b\u300d\u3092\u4e00\u6587\u3067\u7f6e\u304d\u307e\u3059\u3002\u305f\u3068\u3048\u3070\u3001\u65c5\u884c\u306a\u3089\u4e88\u7d04\u5185\u5bb9\u306e\u78ba\u8a8d\u3001\u4f1a\u8b70\u306a\u3089\u6b21\u306e\u62c5\u5f53\u3068\u7de0\u5207\u3001\u6388\u696d\u306a\u3089\u7406\u89e3\u3067\u304d\u306a\u304b\u3063\u305f\u6982\u5ff5\u306e\u8cea\u554f\u3067\u3059\u3002\u76ee\u7684\u304c\u5b9a\u307e\u308b\u3068\u3001\u7ffb\u8a33\u306b\u983c\u308b\u7bc4\u56f2\u3082\u81ea\u7136\u306b\u7d5e\u308c\u307e\u3059\u3002\u6b21\u306b\u3001\u56fa\u6709\u540d\u8a5e\u3001\u88fd\u54c1\u540d\u3001\u7565\u8a9e\u3001\u5730\u540d\u3001\u6570\u5b57\u3092\u30e1\u30e2\u3057\u3066\u304a\u304d\u307e\u3059\u3002\u97f3\u58f0\u8a8d\u8b58\u306f\u80cc\u666f\u97f3\u3084\u767a\u97f3\u306e\u5dee\u306e\u5f71\u97ff\u3092\u53d7\u3051\u308b\u305f\u3081\u3001\u56fa\u6709\u540d\u8a5e\u3092\u6700\u521d\u304b\u3089\u6b63\u78ba\u306b\u62fe\u3048\u308b\u3068\u306f\u9650\u308a\u307e\u305b\u3093\u3002\u9759\u304b\u306a\u5834\u6240\u3001\u5341\u5206\u306a\u5145\u96fb\u3001\u5b89\u5b9a\u3057\u305f\u901a\u4fe1\u3001\u30a4\u30e4\u30db\u30f3\u306e\u6709\u7121\u3082\u77ed\u3044\u4f1a\u8a71\u307b\u3069\u52b9\u304d\u307e\u3059\u3002\u76f8\u624b\u306b\u306f\u958b\u59cb\u524d\u306b\u300c\u7ffb\u8a33\u3092\u88dc\u52a9\u3068\u3057\u3066\u4f7f\u3063\u3066\u3088\u3044\u3067\u3059\u304b\u300d\u3068\u4f1d\u3048\u3001\u9332\u97f3\u3084\u4fdd\u5b58\u306e\u6271\u3044\u3082\u5171\u6709\u3057\u3066\u304f\u3060\u3055\u3044\u3002",
  "ai_live_translation.conversation_heading": "\u77ed\u304f\u533a\u5207\u308a\u3001\u8a00\u3044\u63db\u3048\u3092\u6b53\u8fce\u3059\u308b",
  "ai_live_translation.conversation_body": "\u30e9\u30a4\u30d6\u7ffb\u8a33\u3067\u6700\u3082\u52b9\u679c\u304c\u51fa\u3084\u3059\u3044\u8a71\u3057\u65b9\u306f\u3001\u3086\u3063\u304f\u308a\u8a71\u3059\u3053\u3068\u3088\u308a\u3082\u3001\u4e00\u6587\u3092\u77ed\u304f\u3057\u3066\u4e00\u3064\u306e\u610f\u56f3\u306b\u7d5e\u308b\u3053\u3068\u3067\u3059\u3002\u300c\u6765\u9031\u306e\u706b\u66dc\u3001\u73fe\u5730\u6642\u9593\u306e\u5348\u5f8c3\u6642\u3067\u5408\u3063\u3066\u3044\u307e\u3059\u304b\u300d\u306e\u3088\u3046\u306b\u3001\u65e5\u4ed8\u30fb\u6642\u523b\u30fb\u78ba\u8a8d\u3057\u305f\u3044\u5185\u5bb9\u3092\u4e00\u5ea6\u306b\u8a70\u3081\u8fbc\u307f\u3059\u304e\u306a\u3044\u3088\u3046\u306b\u3057\u307e\u3059\u3002\u8fd4\u7b54\u304c\u8868\u793a\u3055\u308c\u305f\u3089\u3001\u91cd\u8981\u306a\u70b9\u3092\u81ea\u5206\u306e\u8a00\u8449\u3067\u8a00\u3044\u76f4\u3057\u307e\u3059\u3002\u300e\u3064\u307e\u308a\u3001\u7de0\u5207\u306f\u706b\u66dc\u65e5\u3067\u3001\u6642\u523b\u306f\u5348\u5f8c3\u6642\u3067\u3059\u306d\u300f\u3068\u3044\u3046\u78ba\u8a8d\u306f\u3001\u7ffb\u8a33\u306e\u8aa4\u308a\u3060\u3051\u3067\u306a\u304f\u3001\u4eba\u540c\u58eb\u306e\u601d\u3044\u8fbc\u307f\u3082\u898b\u3064\u3051\u307e\u3059\u3002\u6163\u7528\u53e5\u3001\u76ae\u8089\u3001\u5197\u8ac7\u3001\u66d6\u6627\u306a\u4e3b\u8a9e\u306f\u6a5f\u68b0\u304c\u53d6\u308a\u9055\u3048\u3084\u3059\u3044\u9818\u57df\u3067\u3059\u3002\u901a\u3058\u306a\u3044\u3068\u304d\u306f\u8a9e\u5f59\u3092\u96e3\u3057\u304f\u3059\u308b\u306e\u3067\u306f\u306a\u304f\u3001\u4e3b\u8a9e\u3092\u88dc\u3044\u3001\u80af\u5b9a\u30fb\u5426\u5b9a\u3092\u306f\u3063\u304d\u308a\u8a00\u3044\u3001\u5225\u306e\u8868\u73fe\u306b\u8a00\u3044\u63db\u3048\u307e\u3057\u3087\u3046\u3002",
  "ai_live_translation.verify_heading": "\u91cd\u8981\u4e8b\u9805\u306f\u300c\u805e\u3053\u3048\u305f\u300d\u3067\u306f\u306a\u304f\u3001\u8a18\u9332\u3068\u5fa9\u5531\u3067\u78ba\u5b9a\u3059\u308b",
  "ai_live_translation.verify_body": "\u5951\u7d04\u3001\u652f\u6255\u3044\u3001\u533b\u7642\u3001\u5b89\u5168\u3001\u63a1\u7528\u306e\u3088\u3046\u306b\u7d50\u679c\u306e\u91cd\u3044\u4f1a\u8a71\u3067\u306f\u3001\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3060\u3051\u3067\u78ba\u5b9a\u3055\u305b\u306a\u3044\u3053\u3068\u304c\u539f\u5247\u3067\u3059\u3002\u91d1\u984d\u3001\u901a\u8ca8\u3001\u65e5\u4ed8\u3001\u4f4f\u6240\u3001\u62c5\u5f53\u8005\u540d\u3001\u6761\u4ef6\u306f\u753b\u9762\u4e0a\u306e\u6587\u5b57\u3067\u3082\u78ba\u8a8d\u3057\u3001\u53cc\u65b9\u304c\u5fa9\u5531\u3057\u307e\u3059\u3002\u4f1a\u8b70\u306a\u3089\u3001\u7d42\u308f\u308a\u306b\u6c7a\u5b9a\u4e8b\u9805\u30fb\u62c5\u5f53\u8005\u30fb\u671f\u9650\u3092\u7b87\u6761\u66f8\u304d\u306b\u3057\u3066\u5171\u6709\u3059\u308b\u3068\u3088\u3044\u3067\u3057\u3087\u3046\u3002\u7ffb\u8a33\u6587\u306f\u8b70\u4e8b\u9332\u305d\u306e\u3082\u306e\u3067\u306f\u306a\u304f\u3001\u7406\u89e3\u3092\u5408\u308f\u305b\u308b\u305f\u3081\u306e\u4e0b\u66f8\u304d\u3067\u3059\u3002\u6b63\u5f0f\u306a\u5951\u7d04\u3084\u8a3a\u7642\u306e\u8aac\u660e\u306b\u306f\u3001\u5fc5\u8981\u306b\u5fdc\u3058\u3066\u5c02\u9580\u306e\u901a\u8a33\u8005\u3084\u516c\u7684\u306a\u6848\u5185\u3092\u4f7f\u3063\u3066\u304f\u3060\u3055\u3044\u3002\u901f\u3055\u3092\u512a\u5148\u3057\u3066\u66d6\u6627\u306a\u5408\u610f\u3092\u4f5c\u308b\u3088\u308a\u3001\u4e00\u5206\u591a\u304f\u4f7f\u3063\u3066\u78ba\u8a8d\u3059\u308b\u307b\u3046\u304c\u3001\u5f8c\u306e\u3084\u308a\u76f4\u3057\u3092\u5927\u304d\u304f\u6e1b\u3089\u3057\u307e\u3059\u3002",
  "ai_live_translation.privacy_heading": "\u4fbf\u5229\u3055\u306e\u524d\u306b\u3001\u97f3\u58f0\u306e\u884c\u304d\u5148\u3092\u78ba\u8a8d\u3059\u308b",
  "ai_live_translation.privacy_body": "\u97f3\u58f0\u7ffb\u8a33\u306f\u3001\u4f1a\u8a71\u305d\u306e\u3082\u306e\u3092\u6271\u3044\u307e\u3059\u3002\u4f7f\u7528\u3059\u308b\u30b5\u30fc\u30d3\u30b9\u306b\u3064\u3044\u3066\u3001\u97f3\u58f0\u304c\u7aef\u672b\u5185\u3067\u51e6\u7406\u3055\u308c\u308b\u306e\u304b\u3001\u5916\u90e8\u306e\u30b5\u30fc\u30d0\u30fc\u306b\u9001\u3089\u308c\u308b\u306e\u304b\u3001\u5c65\u6b74\u3084\u9332\u97f3\u304c\u6b8b\u308b\u306e\u304b\u3001\u5b66\u7fd2\u5229\u7528\u306e\u8a2d\u5b9a\u3092\u5909\u3048\u3089\u308c\u308b\u306e\u304b\u3092\u78ba\u8a8d\u3057\u307e\u3057\u3087\u3046\u3002\u4f1a\u8b70\u5ba4\u306b\u7b2c\u4e09\u8005\u306e\u58f0\u304c\u5165\u308b\u3001\u753b\u9762\u306b\u9867\u5ba2\u60c5\u5831\u304c\u6620\u308b\u3001\u3068\u3044\u3063\u305f\u72b6\u6cc1\u306b\u3082\u6ce8\u610f\u304c\u5fc5\u8981\u3067\u3059\u3002\u516c\u958b\u306e\u5834\u3067\u306f\u30a4\u30e4\u30db\u30f3\u3092\u4f7f\u3044\u3001\u753b\u9762\u3092\u306e\u305e\u304b\u308c\u306a\u3044\u4f4d\u7f6e\u306b\u7f6e\u304d\u307e\u3059\u3002\u6a5f\u5bc6\u60c5\u5831\u3092\u542b\u3080\u4f1a\u8a71\u3067\u306f\u3001\u7d44\u7e54\u306e\u30eb\u30fc\u30eb\u3068\u5229\u7528\u898f\u7d04\u3092\u78ba\u8a8d\u3057\u3001\u8a31\u53ef\u3055\u308c\u3066\u3044\u306a\u3044\u500b\u4eba\u5411\u3051\u30b5\u30fc\u30d3\u30b9\u3078\u5b89\u6613\u306b\u6d41\u3055\u306a\u3044\u3053\u3068\u304c\u91cd\u8981\u3067\u3059\u3002\u7ffb\u8a33\u306e\u7cbe\u5ea6\u3068\u540c\u3058\u304f\u3089\u3044\u3001\u8ab0\u304c\u4f55\u3092\u5171\u6709\u3059\u308b\u304b\u3092\u9078\u3079\u308b\u3053\u3068\u304c\u5b89\u5fc3\u306b\u3064\u306a\u304c\u308a\u307e\u3059\u3002",
  "ai_live_translation.takeaway_heading": "AI\u306f\u300c\u5b8c\u74a7\u306a\u901a\u8a33\u300d\u3067\u306f\u306a\u304f\u3001\u5bfe\u8a71\u3092\u59cb\u3081\u308b\u305f\u3081\u306e\u9053\u5177",
