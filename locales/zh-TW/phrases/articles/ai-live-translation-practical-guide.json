{
  "AI・デジタル活用": "AI 與數位生活",
  "AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f7f\u3044\u3053\u306a\u3059\u305f\u3081\u306e\u5b9f\u8df5\u30ac\u30a4\u30c9\uff5c\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u5931\u6557\u3057\u306a\u30445\u3064\u306e\u30eb\u30fc\u30eb": "\u5373\u6642 AI \u7ffb\u8b6f\u5be6\u7528\u6307\u5357\uff1a\u6703\u8b70\u3001\u65c5\u884c\u8207\u5b78\u7fd2\u7684\u4e94\u9805\u539f\u5247",
  "Gemini 3.5 Live Translate\u3068Android 17\u306e\u52d5\u5411\u3092\u624b\u304c\u304b\u308a\u306b\u3001AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u6b63\u78ba\u304b\u3064\u5b89\u5fc3\u3057\u3066\u4f7f\u3046\u305f\u3081\u306e\u6e96\u5099\u3001\u4f1d\u3048\u65b9\u3001\u78ba\u8a8d\u65b9\u6cd5\u3001\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u306e\u8003\u3048\u65b9\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002": "\u4ee5 Gemini 3.5 Live Translate \u8207 Android 17 \u7684\u6700\u65b0\u52d5\u5411\u70ba\u7dda\u7d22\uff0c\u8aaa\u660e\u5982\u4f55\u5728\u6703\u8b70\u3001\u65c5\u884c\u8207\u5b78\u7fd2\u4e2d\u6e96\u78ba\u4e14\u5b89\u5fc3\u5730\u4f7f\u7528\u5373\u6642 AI \u7ffb\u8b6f\u3002",
  "ai_live_translation.title": "\u5373\u6642 AI \u7ffb\u8b6f\u5be6\u7528\u6307\u5357",
  "ai_live_translation.heading": "\u8b93\u5373\u6642\u7ffb\u8b6f\u6210\u70ba\u5c0d\u8a71\u7684\u53ef\u9760\u8f14\u52a9",
  "ai_live_translation.description": "\u4ee5 Gemini 3.5 Live Translate \u8207 Android 17 \u7684\u6700\u65b0\u52d5\u5411\u70ba\u7dda\u7d22\uff0c\u8aaa\u660e\u5982\u4f55\u5728\u6703\u8b70\u3001\u65c5\u884c\u8207\u5b78\u7fd2\u4e2d\u6e96\u78ba\u4e14\u5b89\u5fc3\u5730\u4f7f\u7528\u5373\u6642 AI \u7ffb\u8b6f\u3002",
  "ai_live_translation.keywords": "\u5373\u6642 AI \u7ffb\u8b6f, \u5373\u6642\u8a9e\u97f3\u7ffb\u8b6f, Gemini Live Translate, \u591a\u8a9e\u6703\u8b70",
  "ai_live_translation.body": "<p>\u5373\u6642 AI \u7ffb\u8b6f\u65e9\u5df2\u4e0d\u53ea\u662f\u65c5\u884c\u529f\u80fd\uff1b\u5b83\u80fd\u5354\u52a9\u8207\u6d77\u5916\u5ba2\u6236\u901a\u8a71\u3001\u5171\u540c\u5b78\u7fd2\u548c\u65e5\u5e38\u8a62\u554f\u3002\u4e0d\u904e\uff0c\u53e5\u5b50\u6d41\u66a2\u4e0d\u4ee3\u8868\u5b8c\u5168\u6b63\u78ba\uff1a\u4e00\u500b\u5b57\u5c31\u53ef\u80fd\u6539\u8b8a\u59d3\u540d\u3001\u91d1\u984d\u3001\u65e5\u671f\u6216\u540c\u610f\u7684\u610f\u601d\u3002\u61c9\u5c07 AI \u8996\u70ba\u96d9\u65b9\u6838\u5c0d\u610f\u601d\u7684\u5de5\u5177\uff0c\u800c\u975e\u4e0d\u7d93\u5224\u65b7\u5c31\u53d6\u4ee3\u4eba\u5de5\u6e9d\u901a\u3002</p><h3>\u7ffb\u8b6f\u6b63\u8d70\u9032\u5c0d\u8a71\u672c\u8eab</h3><p>Google \u65bc 2026 \u5e74 7 \u6708 1 \u65e5\u4ecb\u7d39 Gemini 3.5 Live Translate\u3002\u5b98\u65b9\u8868\u793a\uff0c\u5b83\u53ef\u81ea\u52d5\u8fa8\u8b58\u8d85\u904e 70 \u7a2e\u8a9e\u8a00\u3001\u4fdd\u7559\u81ea\u7136\u8a9e\u8abf\u4e26\u6e1b\u5c11\u505c\u9813\uff0c\u9810\u8a08\u900f\u904e Gemini Live API\u3001Google AI Studio \u8207 Google \u7ffb\u8b6f\u63d0\u4f9b\u3002\u4f7f\u7528\u524d\u8acb\u78ba\u8a8d\u5730\u5340\u3001\u8a9e\u8a00\u53ca\u88dd\u7f6e\u662f\u5426\u652f\u63f4\u3002</p><h3>\u4e94\u9805\u5be6\u7528\u539f\u5247</h3><p><strong>\u7b2c\u4e00\uff0c</strong>\u7528\u4e00\u53e5\u8a71\u8aaa\u6e05\u695a\u76ee\u7684\u3002<strong>\u7b2c\u4e8c\uff0c</strong>\u5148\u6e96\u5099\u59d3\u540d\u3001\u7e2e\u5beb\u8207\u6578\u5b57\u3002<strong>\u7b2c\u4e09\uff0c</strong>\u4e00\u53e5\u53ea\u8868\u9054\u4e00\u500b\u610f\u601d\uff0c\u4e26\u8986\u8ff0\u91cd\u9ede\uff1a\u300c\u661f\u671f\u4e8c\u4e0b\u5348\u4e09\u9ede\uff0c\u5c0d\u55ce\uff1f\u300d\u907f\u514d\u53cd\u8af7\u8207\u7701\u7565\u4e3b\u8a5e\u3002<strong>\u7b2c\u56db\uff0c</strong>\u5408\u7d04\u3001\u4ed8\u6b3e\u3001\u91ab\u7642\u8207\u5b89\u5168\u4e8b\u9805\u4e00\u5b9a\u8981\u66f8\u9762\u78ba\u8a8d\uff1b\u7ffb\u8b6f\u53ea\u662f\u7406\u89e3\u7684\u8349\u7a3f\uff0c\u4e0d\u662f\u6b63\u5f0f\u7d00\u9304\u3002<strong>\u7b2c\u4e94\uff0c</strong>\u4e86\u89e3\u97f3\u8a0a\u662f\u5728\u88dd\u7f6e\u9084\u662f\u4f3a\u670d\u5668\u8655\u7406\u3001\u662f\u5426\u7559\u5b58\u3002\u516c\u5171\u5834\u5408\u8acb\u7528\u8033\u6a5f\uff0c\u6a5f\u5bc6\u5167\u5bb9\u53ea\u7528\u6838\u51c6\u7684\u670d\u52d9\u3002</p><h3>\u5b83\u662f\u958b\u555f\u5c0d\u8a71\u7684\u5de5\u5177</h3><p>\u50f9\u503c\u4e0d\u5728\u81ea\u52d5\u5b8c\u6210\u6bcf\u4e00\u53e5\u8a71\uff0c\u800c\u5728\u8b93\u4eba\u80fd\u5148\u958b\u53e3\u3001\u6838\u5c0d\u4e26\u518d\u6b21\u63d0\u554f\u3002\u51fa\u73fe\u4e0d\u81ea\u7136\u7684\u7ffb\u8b6f\u4e0d\u662f\u5931\u6557\uff0c\u800c\u662f\u653e\u6162\u8173\u6b65\u3001\u5171\u540c\u78ba\u8a8d\u610f\u601d\u7684\u63d0\u9192\u3002</p><h3>\u53c3\u8003\u6700\u65b0\u8cc7\u8a0a</h3><p><a href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-june-2026/\" target=\"_blank\" rel=\"noopener noreferrer\">Google\uff1a2026 \u5e74 6 \u6708 AI \u66f4\u65b0</a>\uff0c2026 \u5e74 7 \u6708 1 \u65e5\u767c\u5e03\u3002</p>"
}
