{
  "AI・デジタル活用": "ШІ та цифрове життя",
  "AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f7f\u3044\u3053\u306a\u3059\u305f\u3081\u306e\u5b9f\u8df5\u30ac\u30a4\u30c9\uff5c\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u5931\u6557\u3057\u306a\u30445\u3064\u306e\u30eb\u30fc\u30eb": "\u041f\u0440\u0430\u043a\u0442\u0438\u0447\u043d\u0438\u0439 \u043f\u043e\u0441\u0456\u0431\u043d\u0438\u043a \u0456\u0437 \u0428\u0406-\u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434\u0443 \u0432 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u0447\u0430\u0441\u0456: \u043f\u2019\u044f\u0442\u044c \u043f\u0440\u0430\u0432\u0438\u043b \u0434\u043b\u044f \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0435\u0439, \u043f\u043e\u0434\u043e\u0440\u043e\u0436\u0435\u0439 \u0456 \u043d\u0430\u0432\u0447\u0430\u043d\u043d\u044f",
  "Gemini 3.5 Live Translate\u3068Android 17\u306e\u52d5\u5411\u3092\u624b\u304c\u304b\u308a\u306b\u3001AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u6b63\u78ba\u304b\u3064\u5b89\u5fc3\u3057\u3066\u4f7f\u3046\u305f\u3081\u306e\u6e96\u5099\u3001\u4f1d\u3048\u65b9\u3001\u78ba\u8a8d\u65b9\u6cd5\u3001\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u306e\u8003\u3048\u65b9\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002": "\u041d\u0430 \u043e\u0441\u043d\u043e\u0432\u0456 \u043d\u043e\u0432\u0438\u043d \u043f\u0440\u043e Gemini 3.5 Live Translate \u0442\u0430 Android 17 \u043f\u043e\u044f\u0441\u043d\u044e\u0454\u043c\u043e, \u044f\u043a \u0442\u043e\u0447\u043d\u043e \u0439 \u0431\u0435\u0437\u043f\u0435\u0447\u043d\u043e \u043a\u043e\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0442\u0438\u0441\u044f \u0428\u0406-\u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434\u043e\u043c \u0443 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u0447\u0430\u0441\u0456.",
  "ai_live_translation.title": "\u041f\u0440\u0430\u043a\u0442\u0438\u0447\u043d\u0438\u0439 \u043f\u043e\u0441\u0456\u0431\u043d\u0438\u043a \u0456\u0437 \u0428\u0406-\u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434\u0443 \u0432 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u0447\u0430\u0441\u0456",
  "ai_live_translation.heading": "\u0417\u0440\u043e\u0431\u0456\u0442\u044c \u0436\u0438\u0432\u0438\u0439 \u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434 \u043f\u043e\u043c\u0456\u0447\u043d\u0438\u043a\u043e\u043c \u0443 \u0440\u043e\u0437\u043c\u043e\u0432\u0456",
  "ai_live_translation.description": "\u041d\u0430 \u043e\u0441\u043d\u043e\u0432\u0456 \u043d\u043e\u0432\u0438\u043d \u043f\u0440\u043e Gemini 3.5 Live Translate \u0442\u0430 Android 17 \u043f\u043e\u044f\u0441\u043d\u044e\u0454\u043c\u043e, \u044f\u043a \u0442\u043e\u0447\u043d\u043e \u0439 \u0431\u0435\u0437\u043f\u0435\u0447\u043d\u043e \u043a\u043e\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0442\u0438\u0441\u044f \u0428\u0406-\u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434\u043e\u043c \u0443 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u0447\u0430\u0441\u0456.",
  "ai_live_translation.keywords": "\u0428\u0406-\u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434 \u0443 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u0447\u0430\u0441\u0456, \u0433\u043e\u043b\u043e\u0441\u043e\u0432\u0438\u0439 \u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434, Gemini Live Translate, \u0431\u0430\u0433\u0430\u0442\u043e\u043c\u043e\u0432\u043d\u0456 \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0456",
  "ai_live_translation.body": "<p>\u0428\u0406-\u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434 \u0443 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u0447\u0430\u0441\u0456 \u043a\u043e\u0440\u0438\u0441\u043d\u0438\u0439 \u043d\u0435 \u043b\u0438\u0448\u0435 \u0432 \u043f\u043e\u0434\u043e\u0440\u043e\u0436\u0456: \u0432\u0456\u043d \u0434\u043e\u043f\u043e\u043c\u0430\u0433\u0430\u0454 \u0432 \u0440\u043e\u0437\u043c\u043e\u0432\u0456 \u0437 \u0456\u043d\u043e\u0437\u0435\u043c\u043d\u0438\u043c \u043a\u043b\u0456\u0454\u043d\u0442\u043e\u043c, \u0441\u043f\u0456\u043b\u044c\u043d\u043e\u043c\u0443 \u043d\u0430\u0432\u0447\u0430\u043d\u043d\u0456 \u0442\u0430 \u0449\u043e\u0434\u0435\u043d\u043d\u0438\u0445 \u0441\u043f\u0440\u0430\u0432\u0430\u0445. \u041f\u0440\u043e\u0442\u0435 \u043f\u043b\u0430\u0432\u043d\u0438\u0439 \u0442\u0435\u043a\u0441\u0442 \u043d\u0435 \u0433\u0430\u0440\u0430\u043d\u0442\u0443\u0454 \u0442\u043e\u0447\u043d\u043e\u0441\u0442\u0456: \u043e\u0434\u043d\u0435 \u0441\u043b\u043e\u0432\u043e \u043c\u043e\u0436\u0435 \u0437\u043c\u0456\u043d\u0438\u0442\u0438 \u0456\u043c\u2019\u044f, \u0441\u0443\u043c\u0443, \u0434\u0430\u0442\u0443 \u0430\u0431\u043e \u0437\u0433\u043e\u0434\u0443. \u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0439\u0442\u0435 \u0428\u0406 \u0434\u043b\u044f \u0441\u043f\u0456\u043b\u044c\u043d\u043e\u0457 \u043f\u0435\u0440\u0435\u0432\u0456\u0440\u043a\u0438 \u0437\u043c\u0456\u0441\u0442\u0443, \u0430 \u043d\u0435 \u044f\u043a \u0437\u0430\u043c\u0456\u043d\u0443 \u0443\u0432\u0430\u0436\u043d\u043e\u0441\u0442\u0456.</p><h3>\u041f\u0435\u0440\u0435\u043a\u043b\u0430\u0434 \u0441\u0442\u0430\u0454 \u0447\u0430\u0441\u0442\u0438\u043d\u043e\u044e \u0440\u043e\u0437\u043c\u043e\u0432\u0438</h3><p>1 \u043b\u0438\u043f\u043d\u044f 2026 \u0440\u043e\u043a\u0443 Google \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043b\u0430 Gemini 3.5 Live Translate. \u0417\u0430 \u0430\u043d\u043e\u043d\u0441\u043e\u043c, \u0441\u0438\u0441\u0442\u0435\u043c\u0430 \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u043d\u043e \u0440\u043e\u0437\u043f\u0456\u0437\u043d\u0430\u0454 \u043f\u043e\u043d\u0430\u0434 70 \u043c\u043e\u0432, \u0437\u0431\u0435\u0440\u0456\u0433\u0430\u0454 \u0456\u043d\u0442\u043e\u043d\u0430\u0446\u0456\u044e \u0456 \u0437\u043c\u0435\u043d\u0448\u0443\u0454 \u043f\u0430\u0443\u0437\u0438; \u0457\u0457 \u043f\u043b\u0430\u043d\u0443\u044e\u0442\u044c \u043d\u0430\u0434\u0430\u0442\u0438 \u0447\u0435\u0440\u0435\u0437 Gemini Live API, Google AI Studio \u0442\u0430 Google \u041f\u0435\u0440\u0435\u043a\u043b\u0430\u0434\u0430\u0447. \u041f\u0435\u0440\u0435\u0434 \u043f\u043e\u0447\u0430\u0442\u043a\u043e\u043c \u043f\u0435\u0440\u0435\u0432\u0456\u0440\u0442\u0435 \u043f\u0456\u0434\u0442\u0440\u0438\u043c\u043a\u0443 \u043c\u043e\u0432\u0438, \u043a\u0440\u0430\u0457\u043d\u0438 \u0439 \u043f\u0440\u0438\u0441\u0442\u0440\u043e\u044e.</p><h3>\u041f\u2019\u044f\u0442\u044c \u043f\u0440\u0430\u0432\u0438\u043b</h3><p><strong>1.</strong> \u0421\u043a\u0430\u0436\u0456\u0442\u044c \u043c\u0435\u0442\u0443 \u043e\u0434\u043d\u0438\u043c \u0440\u0435\u0447\u0435\u043d\u043d\u044f\u043c. <strong>2.</strong> \u041f\u0456\u0434\u0433\u043e\u0442\u0443\u0439\u0442\u0435 \u0456\u043c\u0435\u043d\u0430, \u0441\u043a\u043e\u0440\u043e\u0447\u0435\u043d\u043d\u044f \u0442\u0430 \u0447\u0438\u0441\u043b\u0430. <strong>3.</strong> \u041e\u0434\u043d\u0430 \u0434\u0443\u043c\u043a\u0430 \u2014 \u043e\u0434\u043d\u0435 \u0440\u0435\u0447\u0435\u043d\u043d\u044f, \u043f\u043e\u0432\u0442\u043e\u0440\u044e\u0439\u0442\u0435 \u0432\u0430\u0436\u043b\u0438\u0432\u0435: \u00ab\u0423 \u0432\u0456\u0432\u0442\u043e\u0440\u043e\u043a \u043e \u0442\u0440\u0435\u0442\u0456\u0439, \u0442\u0430\u043a?\u00bb <strong>4.</strong> \u0414\u043e\u0433\u043e\u0432\u043e\u0440\u0438, \u043f\u043b\u0430\u0442\u0435\u0436\u0456, \u043c\u0435\u0434\u0438\u0447\u043d\u0456 \u0439 \u0431\u0435\u0437\u043f\u0435\u043a\u043e\u0432\u0456 \u043f\u0438\u0442\u0430\u043d\u043d\u044f \u043f\u0456\u0434\u0442\u0432\u0435\u0440\u0434\u0436\u0443\u0439\u0442\u0435 \u043f\u0438\u0441\u044c\u043c\u043e\u0432\u043e: \u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434 \u0454 \u0447\u0435\u0440\u043d\u0435\u0442\u043a\u043e\u044e, \u043d\u0435 \u043e\u0444\u0456\u0446\u0456\u0439\u043d\u0438\u043c \u0437\u0430\u043f\u0438\u0441\u043e\u043c. <strong>5.</strong> \u0417\u2019\u044f\u0441\u0443\u0439\u0442\u0435, \u0434\u0435 \u043e\u0431\u0440\u043e\u0431\u043b\u044f\u0454\u0442\u044c\u0441\u044f \u0456 \u0437\u0431\u0435\u0440\u0456\u0433\u0430\u0454\u0442\u044c\u0441\u044f \u0430\u0443\u0434\u0456\u043e. \u0423 \u043f\u0443\u0431\u043b\u0456\u0447\u043d\u043e\u043c\u0443 \u043c\u0456\u0441\u0446\u0456 \u043a\u043e\u0440\u0438\u0441\u0442\u0443\u0439\u0442\u0435\u0441\u044f \u043d\u0430\u0432\u0443\u0448\u043d\u0438\u043a\u0430\u043c\u0438, \u0430 \u043a\u043e\u043d\u0444\u0456\u0434\u0435\u043d\u0446\u0456\u0439\u043d\u0435 \u043e\u0431\u0433\u043e\u0432\u043e\u0440\u044e\u0439\u0442\u0435 \u043b\u0438\u0448\u0435 \u0432 \u0441\u0445\u0432\u0430\u043b\u0435\u043d\u0438\u0445 \u0441\u0435\u0440\u0432\u0456\u0441\u0430\u0445.</p><h3>\u0406\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442 \u0434\u043b\u044f \u0434\u0456\u0430\u043b\u043e\u0433\u0443</h3><p>\u0419\u043e\u0433\u043e \u0446\u0456\u043d\u043d\u0456\u0441\u0442\u044c \u0443 \u0442\u043e\u043c\u0443, \u0449\u043e \u0432\u0456\u043d \u0434\u0430\u0454 \u0437\u043c\u043e\u0433\u0443 \u043f\u043e\u0447\u0430\u0442\u0438, \u043f\u0435\u0440\u0435\u0432\u0456\u0440\u0438\u0442\u0438 \u0439 \u043f\u0435\u0440\u0435\u043f\u0438\u0442\u0430\u0442\u0438. \u041d\u0435\u0437\u0433\u0440\u0430\u0431\u043d\u0438\u0439 \u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434 \u2014 \u0446\u0435 \u0441\u0438\u0433\u043d\u0430\u043b \u0441\u043f\u043e\u0432\u0456\u043b\u044c\u043d\u0438\u0442\u0438\u0441\u044f \u0439 \u0443\u0442\u043e\u0447\u043d\u0438\u0442\u0438 \u0437\u043c\u0456\u0441\u0442 \u0440\u0430\u0437\u043e\u043c.</p><h3>\u0414\u0436\u0435\u0440\u0435\u043b\u043e</h3><p><a href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-june-2026/\" target=\"_blank\" rel=\"noopener noreferrer\">Google: \u043e\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044f \u0428\u0406 \u0437\u0430 \u0447\u0435\u0440\u0432\u0435\u043d\u044c 2026 \u0440\u043e\u043a\u0443</a>, \u043e\u043f\u0443\u0431\u043b\u0456\u043a\u043e\u0432\u0430\u043d\u043e 1 \u043b\u0438\u043f\u043d\u044f 2026 \u0440\u043e\u043a\u0443.</p>"
}
