{
  "AI・デジタル活用": "एआई और डिजिटल उपयोग",
  "AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f7f\u3044\u3053\u306a\u3059\u305f\u3081\u306e\u5b9f\u8df5\u30ac\u30a4\u30c9\uff5c\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u5931\u6557\u3057\u306a\u30445\u3064\u306e\u30eb\u30fc\u30eb": "\u0930\u093f\u092f\u0932-\u091f\u093e\u0907\u092e AI \u0905\u0928\u0941\u0935\u093e\u0926 \u0915\u093e \u0935\u094d\u092f\u093e\u0935\u0939\u093e\u0930\u093f\u0915 \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0915: \u092c\u0948\u0920\u0915, \u092f\u093e\u0924\u094d\u0930\u093e \u0914\u0930 \u0938\u0940\u0916\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u093e\u0901\u091a \u0928\u093f\u092f\u092e",
  "Gemini 3.5 Live Translate\u3068Android 17\u306e\u52d5\u5411\u3092\u624b\u304c\u304b\u308a\u306b\u3001AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u6b63\u78ba\u304b\u3064\u5b89\u5fc3\u3057\u3066\u4f7f\u3046\u305f\u3081\u306e\u6e96\u5099\u3001\u4f1d\u3048\u65b9\u3001\u78ba\u8a8d\u65b9\u6cd5\u3001\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u306e\u8003\u3048\u65b9\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002": "Gemini 3.5 Live Translate \u0914\u0930 Android 17 \u0915\u0940 \u0916\u092c\u0930\u094b\u0902 \u0915\u0947 \u0906\u0927\u093e\u0930 \u092a\u0930 \u092f\u0939 \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0915 \u0930\u093f\u092f\u0932-\u091f\u093e\u0907\u092e AI \u0905\u0928\u0941\u0935\u093e\u0926 \u0915\u093e \u0938\u091f\u0940\u0915 \u0914\u0930 \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924 \u0909\u092a\u092f\u094b\u0917 \u092c\u0924\u093e\u0924\u093e \u0939\u0948\u0964",
  "ai_live_translation.title": "\u0930\u093f\u092f\u0932-\u091f\u093e\u0907\u092e AI \u0905\u0928\u0941\u0935\u093e\u0926 \u0915\u093e \u0935\u094d\u092f\u093e\u0935\u0939\u093e\u0930\u093f\u0915 \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0915",
  "ai_live_translation.heading": "\u0932\u093e\u0907\u0935 \u0905\u0928\u0941\u0935\u093e\u0926 \u0915\u094b \u092c\u093e\u0924\u091a\u0940\u0924 \u0915\u093e \u0938\u0939\u093e\u092f\u0915 \u092c\u0928\u093e\u0907\u090f",
  "ai_live_translation.description": "Gemini 3.5 Live Translate \u0914\u0930 Android 17 \u0915\u0940 \u0916\u092c\u0930\u094b\u0902 \u0915\u0947 \u0906\u0927\u093e\u0930 \u092a\u0930 \u092f\u0939 \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0915 \u0930\u093f\u092f\u0932-\u091f\u093e\u0907\u092e AI \u0905\u0928\u0941\u0935\u093e\u0926 \u0915\u093e \u0938\u091f\u0940\u0915 \u0914\u0930 \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924 \u0909\u092a\u092f\u094b\u0917 \u092c\u0924\u093e\u0924\u093e \u0939\u0948\u0964",
  "ai_live_translation.keywords": "\u0930\u093f\u092f\u0932-\u091f\u093e\u0907\u092e AI \u0905\u0928\u0941\u0935\u093e\u0926, \u0935\u0949\u0907\u0938 \u0905\u0928\u0941\u0935\u093e\u0926, Gemini Live Translate, \u092c\u0939\u0941\u092d\u093e\u0937\u0940 \u092c\u0948\u0920\u0915",
  "ai_live_translation.body": "<p>\u0930\u093f\u092f\u0932-\u091f\u093e\u0907\u092e AI \u0905\u0928\u0941\u0935\u093e\u0926 \u0905\u092c \u0915\u0947\u0935\u0932 \u092f\u093e\u0924\u094d\u0930\u093e \u0915\u0940 \u0938\u0941\u0935\u093f\u0927\u093e \u0928\u0939\u0940\u0902 \u0939\u0948\u0964 \u092f\u0939 \u0935\u093f\u0926\u0947\u0936\u0940 \u0917\u094d\u0930\u093e\u0939\u0915 \u0938\u0947 \u092c\u093e\u0924, \u0938\u092e\u0942\u0939-\u0905\u0927\u094d\u092f\u092f\u0928 \u0914\u0930 \u0930\u094b\u091c\u093c\u092e\u0930\u094d\u0930\u093e \u0915\u0947 \u0915\u093e\u092e \u092e\u0947\u0902 \u092e\u0926\u0926 \u0915\u0930 \u0938\u0915\u0924\u093e \u0939\u0948\u0964 \u092b\u093f\u0930 \u092d\u0940 \u0938\u0939\u091c \u0926\u093f\u0916\u0928\u0947 \u0935\u093e\u0932\u093e \u0935\u093e\u0915\u094d\u092f \u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u0930\u0942\u092a \u0938\u0947 \u0938\u0939\u0940 \u0928\u0939\u0940\u0902 \u0939\u094b\u0924\u093e; \u090f\u0915 \u0936\u092c\u094d\u0926 \u0928\u093e\u092e, \u0930\u0915\u092e, \u0924\u093e\u0930\u0940\u0916 \u092f\u093e \u0938\u0939\u092e\u0924\u093f \u0915\u093e \u0905\u0930\u094d\u0925 \u092c\u0926\u0932 \u0938\u0915\u0924\u093e \u0939\u0948\u0964 AI \u0915\u094b \u0905\u0930\u094d\u0925 \u0938\u093e\u0925 \u092e\u093f\u0932\u0915\u0930 \u091c\u093e\u0901\u091a\u0928\u0947 \u0915\u093e \u0938\u093e\u0927\u0928 \u092e\u093e\u0928\u0947\u0902, \u092e\u093e\u0928\u0935\u0940\u092f \u0938\u093e\u0935\u0927\u093e\u0928\u0940 \u0915\u093e \u0935\u093f\u0915\u0932\u094d\u092a \u0928\u0939\u0940\u0902\u0964</p><h3>\u0905\u0928\u0941\u0935\u093e\u0926 \u092c\u093e\u0924\u091a\u0940\u0924 \u0915\u0947 \u092d\u0940\u0924\u0930 \u0906 \u0930\u0939\u093e \u0939\u0948</h3><p>1 \u091c\u0941\u0932\u093e\u0908 2026 \u0915\u094b Google \u0928\u0947 Gemini 3.5 Live Translate \u092a\u0947\u0936 \u0915\u093f\u092f\u093e\u0964 \u0918\u094b\u0937\u0923\u093e \u0915\u0947 \u0905\u0928\u0941\u0938\u093e\u0930 \u092f\u0939 70 \u0938\u0947 \u0905\u0927\u093f\u0915 \u092d\u093e\u0937\u093e\u090f\u0901 \u092a\u0939\u091a\u093e\u0928\u0924\u093e \u0939\u0948, \u0938\u094d\u0935\u0930 \u092c\u0928\u093e\u090f \u0930\u0916\u0924\u093e \u0939\u0948 \u0914\u0930 \u0935\u093f\u0930\u093e\u092e \u0918\u091f\u093e\u0924\u093e \u0939\u0948; \u0907\u0938\u0947 Gemini Live API, Google AI Studio \u0914\u0930 Google Translate \u092e\u0947\u0902 \u0909\u092a\u0932\u092c\u094d\u0927 \u0915\u0930\u093e\u0928\u0947 \u0915\u0940 \u092f\u094b\u091c\u0928\u093e \u0939\u0948\u0964 \u0909\u092a\u092f\u094b\u0917 \u0938\u0947 \u092a\u0939\u0932\u0947 \u092d\u093e\u0937\u093e, \u0926\u0947\u0936 \u0914\u0930 \u0909\u092a\u0915\u0930\u0923 \u0915\u0947 \u0938\u092e\u0930\u094d\u0925\u0928 \u0915\u0940 \u091c\u093e\u0901\u091a \u0915\u0930\u0947\u0902\u0964</p><h3>\u092a\u093e\u0901\u091a \u0935\u094d\u092f\u093e\u0935\u0939\u093e\u0930\u093f\u0915 \u0928\u093f\u092f\u092e</h3><p><strong>1.</strong> \u0909\u0926\u094d\u0926\u0947\u0936\u094d\u092f \u090f\u0915 \u0935\u093e\u0915\u094d\u092f \u092e\u0947\u0902 \u0915\u0939\u0947\u0902\u0964 <strong>2.</strong> \u0928\u093e\u092e, \u0938\u0902\u0915\u094d\u0937\u0947\u092a \u0914\u0930 \u0905\u0902\u0915 \u092a\u0939\u0932\u0947 \u0930\u0916\u0947\u0902\u0964 <strong>3.</strong> \u090f\u0915 \u0935\u093e\u0915\u094d\u092f \u092e\u0947\u0902 \u090f\u0915 \u0935\u093f\u091a\u093e\u0930 \u0930\u0916\u0947\u0902 \u0914\u0930 \u092e\u0939\u0924\u094d\u0935\u092a\u0942\u0930\u094d\u0923 \u092c\u093e\u0924 \u0926\u094b\u0939\u0930\u093e\u090f\u0901: \u201c\u092e\u0902\u0917\u0932\u0935\u093e\u0930 \u0924\u0940\u0928 \u092c\u091c\u0947, \u0938\u0939\u0940 \u0939\u0948?\u201d <strong>4.</strong> \u0905\u0928\u0941\u092c\u0902\u0927, \u092d\u0941\u0917\u0924\u093e\u0928, \u0938\u094d\u0935\u093e\u0938\u094d\u0925\u094d\u092f \u0914\u0930 \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u0915\u0940 \u092c\u093e\u0924 \u0932\u093f\u0916\u093f\u0924 \u092e\u0947\u0902 \u0924\u092f \u0915\u0930\u0947\u0902; \u0905\u0928\u0941\u0935\u093e\u0926 \u092e\u0938\u094c\u0926\u093e \u0939\u0948, \u0906\u0927\u093f\u0915\u093e\u0930\u093f\u0915 \u0930\u093f\u0915\u0949\u0930\u094d\u0921 \u0928\u0939\u0940\u0902\u0964 <strong>5.</strong> \u091c\u093e\u0928\u0947\u0902 \u0915\u093f \u0911\u0921\u093f\u092f\u094b \u0915\u0939\u093e\u0901 \u0938\u0902\u0938\u093e\u0927\u093f\u0924 \u0914\u0930 \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924 \u0939\u094b\u0924\u093e \u0939\u0948\u0964 \u0938\u093e\u0930\u094d\u0935\u091c\u0928\u093f\u0915 \u091c\u0917\u0939 \u092a\u0930 \u0908\u092f\u0930\u092b\u093c\u094b\u0928 \u0914\u0930 \u0917\u094b\u092a\u0928\u0940\u092f \u0935\u093f\u0937\u092f\u094b\u0902 \u0915\u0947 \u0932\u093f\u090f \u0915\u0947\u0935\u0932 \u0938\u094d\u0935\u0940\u0915\u0943\u0924 \u0938\u0947\u0935\u093e \u092a\u094d\u0930\u092f\u094b\u0917 \u0915\u0930\u0947\u0902\u0964</p><h3>\u0938\u0902\u0935\u093e\u0926 \u0915\u093e \u0938\u093e\u0927\u0928</h3><p>\u0907\u0938\u0915\u093e \u092e\u0942\u0932\u094d\u092f \u092c\u093e\u0924\u091a\u0940\u0924 \u0936\u0941\u0930\u0942 \u0915\u0930\u0928\u0947, \u091c\u093e\u0901\u091a\u0928\u0947 \u0914\u0930 \u092b\u093f\u0930 \u092a\u0942\u091b\u0928\u0947 \u092e\u0947\u0902 \u0939\u0948\u0964 \u0905\u091f\u092a\u091f\u093e \u0905\u0928\u0941\u0935\u093e\u0926 \u0930\u0941\u0915\u0915\u0930 \u0905\u0930\u094d\u0925 \u0938\u093e\u0925 \u0938\u094d\u092a\u0937\u094d\u091f \u0915\u0930\u0928\u0947 \u0915\u093e \u0938\u0902\u0915\u0947\u0924 \u0939\u0948\u0964</p><h3>\u0938\u094d\u0930\u094b\u0924</h3><p><a href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-june-2026/\" target=\"_blank\" rel=\"noopener noreferrer\">Google: \u091c\u0942\u0928 2026 \u0915\u0947 AI \u0905\u092a\u0921\u0947\u091f</a>, 1 \u091c\u0941\u0932\u093e\u0908 2026 \u0915\u094b \u092a\u094d\u0930\u0915\u093e\u0936\u093f\u0924\u0964</p>"
}
