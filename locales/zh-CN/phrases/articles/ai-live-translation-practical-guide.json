{
  "AI・デジタル活用": "AI 与数字生活",
  "AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f7f\u3044\u3053\u306a\u3059\u305f\u3081\u306e\u5b9f\u8df5\u30ac\u30a4\u30c9\uff5c\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u5931\u6557\u3057\u306a\u30445\u3064\u306e\u30eb\u30fc\u30eb": "\u5b9e\u65f6 AI \u7ffb\u8bd1\u5b9e\u7528\u6307\u5357\uff1a\u4f1a\u8bae\u3001\u65c5\u884c\u4e0e\u5b66\u4e60\u7684\u4e94\u9879\u539f\u5219",
  "Gemini 3.5 Live Translate\u3068Android 17\u306e\u52d5\u5411\u3092\u624b\u304c\u304b\u308a\u306b\u3001AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u6b63\u78ba\u304b\u3064\u5b89\u5fc3\u3057\u3066\u4f7f\u3046\u305f\u3081\u306e\u6e96\u5099\u3001\u4f1d\u3048\u65b9\u3001\u78ba\u8a8d\u65b9\u6cd5\u3001\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u306e\u8003\u3048\u65b9\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002": "\u4ee5 Gemini 3.5 Live Translate \u4e0e Android 17 \u7684\u6700\u65b0\u52a8\u6001\u4e3a\u7ebf\u7d22\uff0c\u8bb2\u89e3\u5982\u4f55\u5728\u4f1a\u8bae\u3001\u65c5\u884c\u548c\u5b66\u4e60\u4e2d\u51c6\u786e\u3001\u5b89\u5fc3\u5730\u4f7f\u7528\u5b9e\u65f6 AI \u7ffb\u8bd1\u3002",
  "ai_live_translation.title": "\u5b9e\u65f6 AI \u7ffb\u8bd1\u5b9e\u7528\u6307\u5357",
  "ai_live_translation.heading": "\u8ba9\u5b9e\u65f6\u7ffb\u8bd1\u6210\u4e3a\u5bf9\u8bdd\u7684\u53ef\u9760\u8f85\u52a9",
  "ai_live_translation.description": "\u4ee5 Gemini 3.5 Live Translate \u4e0e Android 17 \u7684\u6700\u65b0\u52a8\u6001\u4e3a\u7ebf\u7d22\uff0c\u8bb2\u89e3\u5982\u4f55\u5728\u4f1a\u8bae\u3001\u65c5\u884c\u548c\u5b66\u4e60\u4e2d\u51c6\u786e\u3001\u5b89\u5fc3\u5730\u4f7f\u7528\u5b9e\u65f6 AI \u7ffb\u8bd1\u3002",
  "ai_live_translation.keywords": "\u5b9e\u65f6 AI \u7ffb\u8bd1, \u5b9e\u65f6\u8bed\u97f3\u7ffb\u8bd1, Gemini Live Translate, \u591a\u8bed\u8a00\u4f1a\u8bae",
  "ai_live_translation.body": "<p>\u5b9e\u65f6 AI \u7ffb\u8bd1\u65e9\u5df2\u4e0d\u53ea\u662f\u65c5\u884c\u529f\u80fd\uff1b\u5b83\u53ef\u4ee5\u5e2e\u52a9\u6d77\u5916\u5ba2\u6237\u6c9f\u901a\u3001\u5c0f\u7ec4\u5b66\u4e60\u548c\u65e5\u5e38\u54a8\u8be2\u3002\u4f46\u8868\u8fbe\u6d41\u7545\u5e76\u4e0d\u7b49\u4e8e\u5b8c\u5168\u6b63\u786e\uff1a\u4e00\u4e2a\u8bcd\u5c31\u53ef\u80fd\u6539\u53d8\u59d3\u540d\u3001\u91d1\u989d\u3001\u65e5\u671f\u6216\u540c\u610f\u7684\u542b\u4e49\u3002\u5e94\u628a AI \u5f53\u4f5c\u53cc\u65b9\u6838\u5bf9\u610f\u601d\u7684\u5de5\u5177\uff0c\u800c\u975e\u4e0d\u52a0\u5224\u65ad\u5730\u66ff\u4ee3\u4eba\u5de5\u6c9f\u901a\u3002</p><h3>\u7ffb\u8bd1\u6b63\u5728\u8fdb\u5165\u5bf9\u8bdd\u672c\u8eab</h3><p>Google \u4e8e 2026 \u5e74 7 \u6708 1 \u65e5\u4ecb\u7ecd\u4e86 Gemini 3.5 Live Translate\u3002\u5b98\u65b9\u79f0\u5176\u53ef\u81ea\u52a8\u8bc6\u522b 70 \u591a\u79cd\u8bed\u8a00\u3001\u4fdd\u7559\u81ea\u7136\u8bed\u8c03\u5e76\u51cf\u5c11\u505c\u987f\uff0c\u8ba1\u5212\u901a\u8fc7 Gemini Live API\u3001Google AI Studio \u548c Google \u7ffb\u8bd1\u63d0\u4f9b\u3002\u4f7f\u7528\u524d\u52a1\u5fc5\u786e\u8ba4\u6240\u5728\u5730\u533a\u3001\u8bed\u8a00\u548c\u8bbe\u5907\u662f\u5426\u652f\u6301\u3002</p><h3>\u4e94\u9879\u5b9e\u7528\u539f\u5219</h3><p><strong>\u7b2c\u4e00\uff0c</strong>\u7528\u4e00\u53e5\u8bdd\u8bf4\u660e\u76ee\u7684\u3002<strong>\u7b2c\u4e8c\uff0c</strong>\u63d0\u524d\u51c6\u5907\u59d3\u540d\u3001\u7f29\u5199\u548c\u6570\u5b57\u3002<strong>\u7b2c\u4e09\uff0c</strong>\u4e00\u53e5\u53ea\u8bf4\u4e00\u4e2a\u610f\u601d\uff0c\u5e76\u590d\u8ff0\u5173\u952e\u5185\u5bb9\uff1a\u201c\u661f\u671f\u4e8c\u4e0b\u5348\u4e09\u70b9\uff0c\u5bf9\u5417\uff1f\u201d\u907f\u514d\u53cd\u8bbd\u548c\u7701\u7565\u4e3b\u8bed\u3002<strong>\u7b2c\u56db\uff0c</strong>\u5408\u540c\u3001\u4ed8\u6b3e\u3001\u533b\u7597\u548c\u5b89\u5168\u4e8b\u9879\u5fc5\u987b\u4e66\u9762\u786e\u8ba4\uff1b\u7ffb\u8bd1\u53ea\u662f\u7406\u89e3\u8349\u7a3f\uff0c\u5e76\u975e\u6b63\u5f0f\u8bb0\u5f55\u3002<strong>\u7b2c\u4e94\uff0c</strong>\u4e86\u89e3\u97f3\u9891\u5728\u8bbe\u5907\u8fd8\u662f\u670d\u52a1\u5668\u5904\u7406\u3001\u662f\u5426\u7559\u5b58\u3002\u516c\u5171\u573a\u6240\u8bf7\u6234\u8033\u673a\uff0c\u673a\u5bc6\u5185\u5bb9\u53ea\u4f7f\u7528\u83b7\u6279\u51c6\u7684\u670d\u52a1\u3002</p><h3>\u5b83\u662f\u5f00\u542f\u5bf9\u8bdd\u7684\u5de5\u5177</h3><p>\u5b83\u7684\u4ef7\u503c\u4e0d\u5728\u81ea\u52a8\u5b8c\u6210\u6bcf\u53e5\u8bdd\uff0c\u800c\u5728\u8ba9\u4eba\u4eec\u80fd\u591f\u5f00\u53e3\u3001\u6838\u5bf9\u5e76\u518d\u6b21\u63d0\u95ee\u3002\u51fa\u73b0\u751f\u786c\u7ffb\u8bd1\u4e0d\u662f\u5931\u8d25\uff0c\u800c\u662f\u653e\u6162\u901f\u5ea6\u3001\u5171\u540c\u786e\u8ba4\u542b\u4e49\u7684\u63d0\u793a\u3002</p><h3>\u53c2\u8003\u6700\u65b0\u4fe1\u606f</h3><p><a href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-june-2026/\" target=\"_blank\" rel=\"noopener noreferrer\">Google\uff1a2026 \u5e74 6 \u6708 AI \u66f4\u65b0</a>\uff0c\u53d1\u5e03\u4e8e 2026 \u5e74 7 \u6708 1 \u65e5\u3002</p>"
}
