{
  "AI・デジタル活用": "এআই ও ডিজিটাল ব্যবহার",
  "AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f7f\u3044\u3053\u306a\u3059\u305f\u3081\u306e\u5b9f\u8df5\u30ac\u30a4\u30c9\uff5c\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u5931\u6557\u3057\u306a\u30445\u3064\u306e\u30eb\u30fc\u30eb": "\u09b0\u09bf\u09af\u09bc\u09c7\u09b2-\u099f\u09be\u0987\u09ae \u098f\u0986\u0987 \u0985\u09a8\u09c1\u09ac\u09be\u09a6\u09c7\u09b0 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0\u09bf\u0995 \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09bf\u0995\u09be: \u09b8\u09ad\u09be, \u09ad\u09cd\u09b0\u09ae\u09a3 \u0993 \u09b6\u09c7\u0996\u09be\u09b0 \u09aa\u09be\u0981\u099a\u099f\u09bf \u09a8\u09bf\u09af\u09bc\u09ae",
  "Gemini 3.5 Live Translate\u3068Android 17\u306e\u52d5\u5411\u3092\u624b\u304c\u304b\u308a\u306b\u3001AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u6b63\u78ba\u304b\u3064\u5b89\u5fc3\u3057\u3066\u4f7f\u3046\u305f\u3081\u306e\u6e96\u5099\u3001\u4f1d\u3048\u65b9\u3001\u78ba\u8a8d\u65b9\u6cd5\u3001\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u306e\u8003\u3048\u65b9\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002": "Gemini 3.5 Live Translate \u0993 Android 17-\u098f\u09b0 \u0996\u09ac\u09b0 \u09a7\u09b0\u09c7 \u098f\u0987 \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09bf\u0995\u09be\u09af\u09bc \u09b0\u09bf\u09af\u09bc\u09c7\u09b2-\u099f\u09be\u0987\u09ae \u098f\u0986\u0987 \u0985\u09a8\u09c1\u09ac\u09be\u09a6 \u09a8\u09bf\u09b0\u09cd\u09ad\u09c1\u09b2 \u0993 \u09a8\u09bf\u09b0\u09be\u09aa\u09a6\u09c7 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0\u09c7\u09b0 \u0989\u09aa\u09be\u09af\u09bc \u09ac\u09b2\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964",
  "ai_live_translation.title": "\u09b0\u09bf\u09af\u09bc\u09c7\u09b2-\u099f\u09be\u0987\u09ae \u098f\u0986\u0987 \u0985\u09a8\u09c1\u09ac\u09be\u09a6\u09c7\u09b0 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0\u09bf\u0995 \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09bf\u0995\u09be",
  "ai_live_translation.heading": "\u09b2\u09be\u0987\u09ad \u0985\u09a8\u09c1\u09ac\u09be\u09a6\u0995\u09c7 \u0995\u09a5\u09cb\u09aa\u0995\u09a5\u09a8\u09c7\u09b0 \u09b8\u09b9\u09be\u09af\u09bc\u0995 \u0995\u09b0\u09c1\u09a8",
  "ai_live_translation.description": "Gemini 3.5 Live Translate \u0993 Android 17-\u098f\u09b0 \u0996\u09ac\u09b0 \u09a7\u09b0\u09c7 \u098f\u0987 \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09bf\u0995\u09be\u09af\u09bc \u09b0\u09bf\u09af\u09bc\u09c7\u09b2-\u099f\u09be\u0987\u09ae \u098f\u0986\u0987 \u0985\u09a8\u09c1\u09ac\u09be\u09a6 \u09a8\u09bf\u09b0\u09cd\u09ad\u09c1\u09b2 \u0993 \u09a8\u09bf\u09b0\u09be\u09aa\u09a6\u09c7 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0\u09c7\u09b0 \u0989\u09aa\u09be\u09af\u09bc \u09ac\u09b2\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964",
  "ai_live_translation.keywords": "\u09b0\u09bf\u09af\u09bc\u09c7\u09b2-\u099f\u09be\u0987\u09ae \u098f\u0986\u0987 \u0985\u09a8\u09c1\u09ac\u09be\u09a6, \u09ad\u09af\u09bc\u09c7\u09b8 \u0985\u09a8\u09c1\u09ac\u09be\u09a6, Gemini Live Translate, \u09ac\u09b9\u09c1\u09ad\u09be\u09b7\u09c0 \u09b8\u09ad\u09be",
  "ai_live_translation.body": "<p>\u09b0\u09bf\u09af\u09bc\u09c7\u09b2-\u099f\u09be\u0987\u09ae \u098f\u0986\u0987 \u0985\u09a8\u09c1\u09ac\u09be\u09a6 \u098f\u0996\u09a8 \u09b6\u09c1\u09a7\u09c1 \u09ad\u09cd\u09b0\u09ae\u09a3\u09c7\u09b0 \u09b8\u09c1\u09ac\u09bf\u09a7\u09be \u09a8\u09af\u09bc; \u09ac\u09bf\u09a6\u09c7\u09b6\u09bf \u0997\u09cd\u09b0\u09be\u09b9\u0995\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u0995\u09a5\u09be, \u09a6\u09b2\u0997\u09a4 \u09aa\u09a1\u09bc\u09be\u09b6\u09cb\u09a8\u09be \u09ac\u09be \u09a6\u09c8\u09a8\u09a8\u09cd\u09a6\u09bf\u09a8 \u0995\u09be\u099c\u09c7 \u098f\u099f\u09bf \u09b8\u09b9\u09be\u09af\u09bc\u0995\u0964 \u09a4\u09ac\u09c7 \u09b8\u09be\u09ac\u09b2\u09c0\u09b2 \u09ac\u09be\u0995\u09cd\u09af \u09ae\u09be\u09a8\u09c7\u0987 \u09a8\u09bf\u09b0\u09cd\u09ad\u09c1\u09b2 \u09a8\u09af\u09bc\u2014\u098f\u0995\u099f\u09bf \u09b6\u09ac\u09cd\u09a6 \u09a8\u09be\u09ae, \u099f\u09be\u0995\u09be, \u09a4\u09be\u09b0\u09bf\u0996 \u09ac\u09be \u09b8\u09ae\u09cd\u09ae\u09a4\u09bf\u09b0 \u0985\u09b0\u09cd\u09a5 \u09ac\u09a6\u09b2\u09c7 \u09a6\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964 \u098f\u0986\u0987\u0995\u09c7 \u0985\u09b0\u09cd\u09a5 \u098f\u0995\u09b8\u0999\u09cd\u0997\u09c7 \u09af\u09be\u099a\u09be\u0987\u09af\u09bc\u09c7\u09b0 \u0989\u09aa\u09be\u09af\u09bc \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0 \u0995\u09b0\u09c1\u09a8, \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09b8\u09a4\u09b0\u09cd\u0995\u09a4\u09be\u09b0 \u09ac\u09bf\u0995\u09b2\u09cd\u09aa \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09a8\u09af\u09bc\u0964</p><h3>\u0985\u09a8\u09c1\u09ac\u09be\u09a6 \u0995\u09a5\u09cb\u09aa\u0995\u09a5\u09a8\u09c7\u09b0 \u09ad\u09c7\u09a4\u09b0\u09c7 \u0986\u09b8\u099b\u09c7</h3><p>\u09e7 \u099c\u09c1\u09b2\u09be\u0987 \u09e8\u09e6\u09e8\u09ec-\u098f Google Gemini 3.5 Live Translate \u09aa\u09b0\u09bf\u099a\u09af\u09bc \u0995\u09b0\u09be\u09af\u09bc\u0964 \u0998\u09cb\u09b7\u09a3\u09be\u09af\u09bc \u09ed\u09e6\u099f\u09bf\u09b0 \u09ac\u09c7\u09b6\u09bf \u09ad\u09be\u09b7\u09be \u09b8\u09cd\u09ac\u09af\u09bc\u0982\u0995\u09cd\u09b0\u09bf\u09af\u09bc\u09ad\u09be\u09ac\u09c7 \u09b6\u09a8\u09be\u0995\u09cd\u09a4 \u0995\u09b0\u09be, \u09b8\u09cd\u09ac\u09b0 \u09ac\u099c\u09be\u09af\u09bc \u09b0\u09be\u0996\u09be \u098f\u09ac\u0982 \u09ac\u09bf\u09b0\u09a4\u09bf \u0995\u09ae\u09be\u09a8\u09cb\u09b0 \u0995\u09a5\u09be \u09ac\u09b2\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7; \u098f\u099f\u09bf Gemini Live API, Google AI Studio \u0993 Google Translate-\u098f \u09a6\u09c7\u0993\u09af\u09bc\u09be\u09b0 \u09aa\u09b0\u09bf\u0995\u09b2\u09cd\u09aa\u09a8\u09be \u09b0\u09af\u09bc\u09c7\u099b\u09c7\u0964 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0\u09c7\u09b0 \u0986\u0997\u09c7 \u09ad\u09be\u09b7\u09be, \u09a6\u09c7\u09b6 \u0993 \u09af\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09b8\u09ae\u09b0\u09cd\u09a5\u09a8 \u09af\u09be\u099a\u09be\u0987 \u0995\u09b0\u09c1\u09a8\u0964</p><h3>\u09aa\u09be\u0981\u099a\u099f\u09bf \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0\u09bf\u0995 \u09a8\u09bf\u09af\u09bc\u09ae</h3><p><strong>\u09e7.</strong> \u09b2\u0995\u09cd\u09b7\u09cd\u09af \u098f\u0995 \u09ac\u09be\u0995\u09cd\u09af\u09c7 \u09ac\u09b2\u09c1\u09a8\u0964 <strong>\u09e8.</strong> \u09a8\u09be\u09ae, \u09b8\u0982\u0995\u09cd\u09b7\u09bf\u09aa\u09cd\u09a4 \u09b0\u09c2\u09aa \u0993 \u09b8\u0982\u0996\u09cd\u09af\u09be \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4 \u09b0\u09be\u0996\u09c1\u09a8\u0964 <strong>\u09e9.</strong> \u09aa\u09cd\u09b0\u09a4\u09bf \u09ac\u09be\u0995\u09cd\u09af\u09c7 \u098f\u0995\u099f\u09bf \u09ad\u09be\u09ac \u09ac\u09b2\u09c1\u09a8 \u098f\u09ac\u0982 \u099c\u09b0\u09c1\u09b0\u09bf \u0995\u09a5\u09be \u09ab\u09c7\u09b0 \u09ac\u09b2\u09c1\u09a8: \u201c\u09ae\u0999\u09cd\u0997\u09b2\u09ac\u09be\u09b0 \u09a4\u09bf\u09a8\u099f\u09be\u09af\u09bc, \u09a0\u09bf\u0995 \u09a4\u09cb?\u201d <strong>\u09ea.</strong> \u099a\u09c1\u0995\u09cd\u09a4\u09bf, \u09aa\u09c7\u09ae\u09c7\u09a8\u09cd\u099f, \u09b8\u09cd\u09ac\u09be\u09b8\u09cd\u09a5\u09cd\u09af \u0993 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be \u09b2\u09bf\u0996\u09bf\u09a4\u09ad\u09be\u09ac\u09c7 \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09c1\u09a8; \u0985\u09a8\u09c1\u09ac\u09be\u09a6 \u0996\u09b8\u09a1\u09bc\u09be, \u0986\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09bf\u0995 \u09a8\u09a5\u09bf \u09a8\u09af\u09bc\u0964 <strong>\u09eb.</strong> \u0985\u09a1\u09bf\u0993 \u0995\u09cb\u09a5\u09be\u09af\u09bc \u09aa\u09cd\u09b0\u0995\u09cd\u09b0\u09bf\u09af\u09bc\u09be\u0995\u09b0\u09a3 \u0993 \u09b8\u0982\u09b0\u0995\u09cd\u09b7\u09a3 \u09b9\u09af\u09bc \u099c\u09be\u09a8\u09c1\u09a8\u0964 \u099c\u09a8\u09b8\u09ae\u0995\u09cd\u09b7\u09c7 \u0987\u09af\u09bc\u09be\u09b0\u09ab\u09cb\u09a8 \u098f\u09ac\u0982 \u0997\u09cb\u09aa\u09a8 \u09ac\u09bf\u09b7\u09af\u09bc\u09c7 \u0985\u09a8\u09c1\u09ae\u09cb\u09a6\u09bf\u09a4 \u09b8\u09c7\u09ac\u09be \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0 \u0995\u09b0\u09c1\u09a8\u0964</p><h3>\u09b8\u0982\u09b2\u09be\u09aa\u09c7\u09b0 \u098f\u0995\u099f\u09bf \u0989\u09aa\u0995\u09b0\u09a3</h3><p>\u098f\u09b0 \u09ae\u09c2\u09b2\u09cd\u09af \u09b9\u09b2\u09cb \u0995\u09a5\u09be \u09b6\u09c1\u09b0\u09c1, \u09af\u09be\u099a\u09be\u0987 \u0993 \u0986\u09ac\u09be\u09b0 \u099c\u09bf\u099c\u09cd\u099e\u09be\u09b8\u09be\u09b0 \u09b8\u09c1\u09af\u09cb\u0997\u0964 \u0985\u09b8\u09cd\u09ac\u09be\u09ad\u09be\u09ac\u09bf\u0995 \u0985\u09a8\u09c1\u09ac\u09be\u09a6 \u09a7\u09c0\u09b0\u09c7 \u0997\u09bf\u09af\u09bc\u09c7 \u098f\u0995\u09b8\u0999\u09cd\u0997\u09c7 \u0985\u09b0\u09cd\u09a5 \u09aa\u09b0\u09bf\u09b7\u09cd\u0995\u09be\u09b0 \u0995\u09b0\u09be\u09b0 \u09b8\u0982\u0995\u09c7\u09a4\u0964</p><h3>\u0989\u09ce\u09b8</h3><p><a href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-june-2026/\" target=\"_blank\" rel=\"noopener noreferrer\">Google: \u099c\u09c1\u09a8 \u09e8\u09e6\u09e8\u09ec-\u098f\u09b0 \u098f\u0986\u0987 \u0986\u09aa\u09a1\u09c7\u099f</a>, \u09aa\u09cd\u09b0\u0995\u09be\u09b6\u09bf\u09a4 \u09e7 \u099c\u09c1\u09b2\u09be\u0987 \u09e8\u09e6\u09e8\u09ec\u0964</p>"
}
