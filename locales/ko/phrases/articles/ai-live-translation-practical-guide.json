{
  "AI・デジタル活用": "AI·디지털 활용",
  "AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f7f\u3044\u3053\u306a\u3059\u305f\u3081\u306e\u5b9f\u8df5\u30ac\u30a4\u30c9\uff5c\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u5931\u6557\u3057\u306a\u30445\u3064\u306e\u30eb\u30fc\u30eb": "\uc2e4\uc2dc\uac04 AI \ubc88\uc5ed \uc2e4\uc804 \uac00\uc774\ub4dc: \ud68c\uc758\u00b7\uc5ec\ud589\u00b7\ud559\uc2b5\uc744 \uc704\ud55c \ub2e4\uc12f \uac00\uc9c0 \uc6d0\uce59",
  "Gemini 3.5 Live Translate\u3068Android 17\u306e\u52d5\u5411\u3092\u624b\u304c\u304b\u308a\u306b\u3001AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u6b63\u78ba\u304b\u3064\u5b89\u5fc3\u3057\u3066\u4f7f\u3046\u305f\u3081\u306e\u6e96\u5099\u3001\u4f1d\u3048\u65b9\u3001\u78ba\u8a8d\u65b9\u6cd5\u3001\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u306e\u8003\u3048\u65b9\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002": "Gemini 3.5 Live Translate\uc640 Android 17 \uc18c\uc2dd\uc744 \ubc14\ud0d5\uc73c\ub85c \uc2e4\uc2dc\uac04 AI \ubc88\uc5ed\uc744 \uc815\ud655\ud558\uace0 \uc548\uc804\ud558\uac8c \uc0ac\uc6a9\ud558\ub294 \ubc29\ubc95\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.",
  "ai_live_translation.title": "\uc2e4\uc2dc\uac04 AI \ubc88\uc5ed \uc2e4\uc804 \uac00\uc774\ub4dc",
  "ai_live_translation.heading": "\uc2e4\uc2dc\uac04 \ubc88\uc5ed\uc744 \ub300\ud654\uc758 \ub4e0\ub4e0\ud55c \ubcf4\uc870 \uc218\ub2e8\uc73c\ub85c",
  "ai_live_translation.description": "Gemini 3.5 Live Translate\uc640 Android 17 \uc18c\uc2dd\uc744 \ubc14\ud0d5\uc73c\ub85c \uc2e4\uc2dc\uac04 AI \ubc88\uc5ed\uc744 \uc815\ud655\ud558\uace0 \uc548\uc804\ud558\uac8c \uc0ac\uc6a9\ud558\ub294 \ubc29\ubc95\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.",
  "ai_live_translation.keywords": "\uc2e4\uc2dc\uac04 AI \ubc88\uc5ed, \uc74c\uc131 \ubc88\uc5ed, Gemini Live Translate, \ub2e4\uad6d\uc5b4 \ud68c\uc758",
  "ai_live_translation.body": "<p>\uc2e4\uc2dc\uac04 AI \ubc88\uc5ed\uc740 \uc774\uc81c \uc5ec\ud589\uac1d\ub9cc\uc744 \uc704\ud55c \uae30\ub2a5\uc774 \uc544\ub2d9\ub2c8\ub2e4. \ud574\uc678 \uace0\uac1d\uacfc\uc758 \ud1b5\ud654, \uacf5\ub3d9 \ud559\uc2b5, \uc77c\uc0c1\uc801\uc778 \ubb38\uc758\uc5d0 \ub3c4\uc6c0\uc744 \uc90d\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \uc790\uc5f0\uc2a4\ub7ec\uc6b4 \ubb38\uc7a5\uc774 \uace7 \uc815\ud655\ud568\uc744 \ub73b\ud558\uc9c0\ub294 \uc54a\uc2b5\ub2c8\ub2e4. \ub2e8\uc5b4 \ud558\ub098\uac00 \uc774\ub984, \uae08\uc561, \ub0a0\uc9dc, \ub3d9\uc758\uc758 \ub73b\uc744 \ubc14\uafc0 \uc218 \uc788\uc2b5\ub2c8\ub2e4. AI\ub97c \ub300\ud654\ub97c \ub9e1\uae30\ub294 \ud1b5\uc5ed\uc0ac\uac00 \uc544\ub2c8\ub77c \uc11c\ub85c\uc758 \ub73b\uc744 \ud655\uc778\ud558\ub294 \ub3c4\uad6c\ub85c \uc0ac\uc6a9\ud558\uc138\uc694.</p><h3>\ubc88\uc5ed\uc774 \ub300\ud654 \uc18d\uc73c\ub85c \ub4e4\uc5b4\uc624\ub2e4</h3><p>Google\uc740 2026\ub144 7\uc6d4 1\uc77c Gemini 3.5 Live Translate\ub97c \uc18c\uac1c\ud588\uc2b5\ub2c8\ub2e4. \ubc1c\ud45c\uc5d0 \ub530\ub974\uba74 70\uac1c \uc774\uc0c1\uc758 \uc5b8\uc5b4\ub97c \uc790\ub3d9 \uac10\uc9c0\ud558\uace0 \uc5b5\uc591\uc744 \uc0b4\ub9ac\uba70 \uba48\ucda4\uc744 \uc904\uc774\ub294 \uc74c\uc131 \ubc88\uc5ed\uc73c\ub85c, Gemini Live API\u00b7Google AI Studio\u00b7Google \ubc88\uc5ed\uc5d0 \uc81c\uacf5\ub420 \uc608\uc815\uc785\ub2c8\ub2e4. \uc0ac\uc6a9 \uc804 \uc5b8\uc5b4, \uad6d\uac00, \uae30\uae30\ubcc4 \uc81c\uacf5 \uc5ec\ubd80\ub97c \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.</p><h3>\uc2e4\uc804 \ub2e4\uc12f \uc6d0\uce59</h3><p><strong>1.</strong> \ub300\ud654 \ubaa9\uc801\uc744 \ud55c \ubb38\uc7a5\uc73c\ub85c \uc815\ud569\ub2c8\ub2e4. <strong>2.</strong> \uc774\ub984, \uc57d\uc5b4, \uc22b\uc790\ub97c \ubbf8\ub9ac \uc900\ube44\ud569\ub2c8\ub2e4. <strong>3.</strong> \ud55c \ubb38\uc7a5\uc5d0\ub294 \ud55c \uac00\uc9c0 \ub73b\ub9cc \ub2f4\uace0 \u201c\ud654\uc694\uc77c \uc624\ud6c4 3\uc2dc, \ub9de\ub098\uc694?\u201d\ucc98\ub7fc \uc911\uc694\ud55c \ub0b4\uc6a9\uc744 \ub418\ubb3b\uc2b5\ub2c8\ub2e4. <strong>4.</strong> \uacc4\uc57d\u00b7\uacb0\uc81c\u00b7\uc758\ub8cc\u00b7\uc548\uc804\uc740 \ubc18\ub4dc\uc2dc \uae00\ub85c \ud655\uc778\ud569\ub2c8\ub2e4. \ubc88\uc5ed\uc740 \ucd08\uc548\uc774\uc9c0 \uacf5\uc2dd \uae30\ub85d\uc774 \uc544\ub2d9\ub2c8\ub2e4. <strong>5.</strong> \uc74c\uc131\uc774 \uae30\uae30 \uc548\uc5d0\uc11c \ucc98\ub9ac\ub418\ub294\uc9c0, \uc11c\ubc84\uc5d0 \uc800\uc7a5\ub418\ub294\uc9c0 \ud655\uc778\ud569\ub2c8\ub2e4. \uacf5\uacf5\uc7a5\uc18c\uc5d0\uc11c\ub294 \uc774\uc5b4\ud3f0\uc744 \uc4f0\uace0 \uae30\ubc00 \ub0b4\uc6a9\uc740 \uc2b9\uc778\ub41c \uc11c\ube44\uc2a4\uc5d0\uc11c\ub9cc \ub2e4\ub8e8\uc138\uc694.</p><h3>\uc644\ubcbd\ud55c \ud1b5\uc5ed\uc774 \uc544\ub2cc \ub300\ud654\uc758 \ub3c4\uad6c</h3><p>\uac00\uce58\ub294 \ubaa8\ub4e0 \ub9d0\uc744 \uc790\ub3d9\ud654\ud558\ub294 \ub370 \uc788\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uba3c\uc800 \ub9d0\ud558\uace0, \ud655\uc778\ud558\uace0, \ub2e4\uc2dc \ubb3c\uc744 \uc5ec\uc9c0\ub97c \ub9cc\ub4dc\ub294 \ub370 \uc788\uc2b5\ub2c8\ub2e4. \uc5b4\uc0c9\ud55c \ubc88\uc5ed\uc740 \uc2e4\ud328\uac00 \uc544\ub2c8\ub77c \ud568\uaed8 \ub73b\uc744 \ub2e4\uc2dc \ub9de\ucd9c \uc2e0\ud638\uc785\ub2c8\ub2e4.</p><h3>\ucc38\uace0\ud55c \ucd5c\uc2e0 \uc815\ubcf4</h3><p><a href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-june-2026/\" target=\"_blank\" rel=\"noopener noreferrer\">Google: 2026\ub144 6\uc6d4 AI \uc5c5\ub370\uc774\ud2b8</a>, 2026\ub144 7\uc6d4 1\uc77c \uacf5\uac1c.</p>"
}
