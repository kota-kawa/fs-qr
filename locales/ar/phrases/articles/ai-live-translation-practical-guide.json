{
  "AI・デジタル活用": "الذكاء الاصطناعي والاستخدام الرقمي",
  "AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f7f\u3044\u3053\u306a\u3059\u305f\u3081\u306e\u5b9f\u8df5\u30ac\u30a4\u30c9\uff5c\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u5931\u6557\u3057\u306a\u30445\u3064\u306e\u30eb\u30fc\u30eb": "\u062f\u0644\u064a\u0644 \u0639\u0645\u0644\u064a \u0644\u0644\u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u0641\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a: \u062e\u0645\u0633 \u0642\u0648\u0627\u0639\u062f \u0644\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u0627\u062a \u0648\u0627\u0644\u0633\u0641\u0631 \u0648\u0627\u0644\u062a\u0639\u0644\u0651\u0645",
  "Gemini 3.5 Live Translate\u3068Android 17\u306e\u52d5\u5411\u3092\u624b\u304c\u304b\u308a\u306b\u3001AI\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u7ffb\u8a33\u3092\u4f1a\u8b70\u30fb\u65c5\u884c\u30fb\u5b66\u7fd2\u3067\u6b63\u78ba\u304b\u3064\u5b89\u5fc3\u3057\u3066\u4f7f\u3046\u305f\u3081\u306e\u6e96\u5099\u3001\u4f1d\u3048\u65b9\u3001\u78ba\u8a8d\u65b9\u6cd5\u3001\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u306e\u8003\u3048\u65b9\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002": "\u0627\u0646\u0637\u0644\u0627\u0642\u064b\u0627 \u0645\u0646 \u0623\u062e\u0628\u0627\u0631 Gemini 3.5 Live Translate \u0648Android 17\u060c \u064a\u0634\u0631\u062d \u0647\u0630\u0627 \u0627\u0644\u062f\u0644\u064a\u0644 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u0641\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0628\u062f\u0642\u0629 \u0648\u0623\u0645\u0627\u0646.",
  "ai_live_translation.title": "\u062f\u0644\u064a\u0644 \u0639\u0645\u0644\u064a \u0644\u0644\u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u0641\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a",
  "ai_live_translation.heading": "\u0627\u062c\u0639\u0644 \u0627\u0644\u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u062d\u064a\u0629 \u0639\u0648\u0646\u064b\u0627 \u0644\u0644\u062d\u0648\u0627\u0631",
  "ai_live_translation.description": "\u0627\u0646\u0637\u0644\u0627\u0642\u064b\u0627 \u0645\u0646 \u0623\u062e\u0628\u0627\u0631 Gemini 3.5 Live Translate \u0648Android 17\u060c \u064a\u0634\u0631\u062d \u0647\u0630\u0627 \u0627\u0644\u062f\u0644\u064a\u0644 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u0641\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0628\u062f\u0642\u0629 \u0648\u0623\u0645\u0627\u0646.",
  "ai_live_translation.keywords": "\u062a\u0631\u062c\u0645\u0629 \u0641\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a, \u062a\u0631\u062c\u0645\u0629 \u0635\u0648\u062a\u064a\u0629, Gemini Live Translate, \u0627\u062c\u062a\u0645\u0627\u0639\u0627\u062a \u0645\u062a\u0639\u062f\u062f\u0629 \u0627\u0644\u0644\u063a\u0627\u062a",
  "ai_live_translation.body": "<p>\u0644\u0645 \u062a\u0639\u062f \u0627\u0644\u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u0641\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0645\u064a\u0632\u0629 \u062e\u0627\u0635\u0629 \u0628\u0627\u0644\u0633\u0641\u0631\u061b \u0641\u0647\u064a \u062a\u0633\u0627\u0639\u062f \u0641\u064a \u0645\u0643\u0627\u0644\u0645\u0629 \u0645\u0639 \u0639\u0645\u064a\u0644 \u0623\u062c\u0646\u0628\u064a \u0623\u0648 \u062f\u0631\u0627\u0633\u0629 \u062c\u0645\u0627\u0639\u064a\u0629 \u0623\u0648 \u0645\u0648\u0642\u0641 \u064a\u0648\u0645\u064a. \u0644\u0643\u0646 \u0627\u0644\u0639\u0628\u0627\u0631\u0629 \u0627\u0644\u0633\u0644\u0633\u0629 \u0644\u064a\u0633\u062a \u0636\u0645\u0627\u0646\u064b\u0627 \u0644\u0644\u062f\u0642\u0629\u061b \u0641\u0643\u0644\u0645\u0629 \u0648\u0627\u062d\u062f\u0629 \u0642\u062f \u062a\u063a\u064a\u0651\u0631 \u0627\u0633\u0645\u064b\u0627 \u0623\u0648 \u0645\u0628\u0644\u063a\u064b\u0627 \u0623\u0648 \u062a\u0627\u0631\u064a\u062e\u064b\u0627 \u0623\u0648 \u0645\u0648\u0627\u0641\u0642\u0629. \u0627\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u0644\u062a\u062d\u0642\u0642 \u0645\u0646 \u0627\u0644\u0645\u0639\u0646\u0649 \u0645\u0639 \u0627\u0644\u0637\u0631\u0641 \u0627\u0644\u0622\u062e\u0631\u060c \u0644\u0627 \u0628\u062f\u064a\u0644\u064b\u0627 \u0639\u0646 \u0627\u0644\u0627\u0646\u062a\u0628\u0627\u0647 \u0627\u0644\u0628\u0634\u0631\u064a.</p><h3>\u0627\u0644\u062a\u0631\u062c\u0645\u0629 \u062a\u062f\u062e\u0644 \u0625\u0644\u0649 \u0635\u0644\u0628 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629</h3><p>\u0641\u064a 1 \u064a\u0648\u0644\u064a\u0648 2026 \u0639\u0631\u0651\u0641\u062a Google \u062e\u062f\u0645\u0629 Gemini 3.5 Live Translate. \u0648\u0648\u0641\u0642 \u0627\u0644\u0625\u0639\u0644\u0627\u0646\u060c \u062a\u0643\u062a\u0634\u0641 \u0627\u0644\u062e\u062f\u0645\u0629 \u0623\u0643\u062b\u0631 \u0645\u0646 70 \u0644\u063a\u0629 \u0648\u062a\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0627\u0644\u0646\u0628\u0631\u0629 \u0648\u062a\u0642\u0644\u0644 \u0641\u062a\u0631\u0627\u062a \u0627\u0644\u062a\u0648\u0642\u0641\u060c \u0645\u0639 \u0625\u062a\u0627\u062d\u062a\u0647\u0627 \u0639\u0628\u0631 Gemini Live API \u0648Google AI Studio \u0648\u062a\u0631\u062c\u0645\u0629 Google. \u062a\u062d\u0642\u0642 \u0645\u0646 \u062f\u0639\u0645 \u0627\u0644\u0644\u063a\u0629 \u0648\u0627\u0644\u0628\u0644\u062f \u0648\u0627\u0644\u062c\u0647\u0627\u0632 \u0642\u0628\u0644 \u0627\u0644\u0627\u0639\u062a\u0645\u0627\u062f \u0639\u0644\u064a\u0647\u0627.</p><h3>\u062e\u0645\u0633 \u0642\u0648\u0627\u0639\u062f \u0639\u0645\u0644\u064a\u0629</h3><p><strong>1.</strong> \u0627\u0630\u0643\u0631 \u0627\u0644\u0647\u062f\u0641 \u0641\u064a \u062c\u0645\u0644\u0629 \u0648\u0627\u062d\u062f\u0629. <strong>2.</strong> \u062c\u0647\u0651\u0632 \u0627\u0644\u0623\u0633\u0645\u0627\u0621 \u0648\u0627\u0644\u0627\u062e\u062a\u0635\u0627\u0631\u0627\u062a \u0648\u0627\u0644\u0623\u0631\u0642\u0627\u0645. <strong>3.</strong> \u0627\u062c\u0639\u0644 \u0643\u0644 \u062c\u0645\u0644\u0629 \u0644\u0641\u0643\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0648\u0643\u0631\u0651\u0631 \u0627\u0644\u0645\u0647\u0645: \u00ab\u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062b\u0627\u0644\u062b\u0629\u060c \u0635\u062d\u064a\u062d\u061f\u00bb. <strong>4.</strong> \u0623\u0643\u0651\u062f \u0627\u0644\u0639\u0642\u0648\u062f \u0648\u0627\u0644\u0645\u062f\u0641\u0648\u0639\u0627\u062a \u0648\u0627\u0644\u0635\u062d\u0629 \u0648\u0627\u0644\u0633\u0644\u0627\u0645\u0629 \u0643\u062a\u0627\u0628\u0629\u064b\u061b \u0641\u0627\u0644\u062a\u0631\u062c\u0645\u0629 \u0645\u0633\u0648\u062f\u0629 \u0648\u0644\u064a\u0633\u062a \u0633\u062c\u0644\u064b\u0627 \u0631\u0633\u0645\u064a\u064b\u0627. <strong>5.</strong> \u0627\u0639\u0631\u0641 \u0623\u064a\u0646 \u064a\u064f\u0639\u0627\u0644\u062c \u0627\u0644\u0635\u0648\u062a \u0648\u064a\u064f\u062d\u0641\u0638. \u0627\u0633\u062a\u062e\u062f\u0645 \u0633\u0645\u0627\u0639\u0627\u062a \u0641\u064a \u0627\u0644\u0623\u0645\u0627\u0643\u0646 \u0627\u0644\u0639\u0627\u0645\u0629 \u0648\u062e\u062f\u0645\u0627\u062a \u0645\u0639\u062a\u0645\u062f\u0629 \u0644\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u0633\u0631\u064a\u0629.</p><h3>\u0623\u062f\u0627\u0629 \u0644\u0644\u062d\u0648\u0627\u0631</h3><p>\u0642\u064a\u0645\u062a\u0647\u0627 \u0641\u064a \u0625\u062a\u0627\u062d\u0629 \u0627\u0644\u0628\u062f\u0621 \u0648\u0627\u0644\u062a\u062d\u0642\u0642 \u0648\u0627\u0644\u0633\u0624\u0627\u0644 \u0645\u0646 \u062c\u062f\u064a\u062f. \u0627\u0644\u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u063a\u0631\u064a\u0628\u0629 \u0625\u0634\u0627\u0631\u0629 \u0625\u0644\u0649 \u0627\u0644\u062a\u0645\u0647\u0651\u0644 \u0648\u0628\u0646\u0627\u0621 \u0627\u0644\u0645\u0639\u0646\u0649 \u0645\u0639\u064b\u0627.</p><h3>\u0627\u0644\u0645\u0635\u062f\u0631</h3><p><a href=\"https://blog.google/innovation-and-ai/technology/ai/google-ai-updates-june-2026/\" target=\"_blank\" rel=\"noopener noreferrer\">Google: \u062a\u062d\u062f\u064a\u062b\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u0634\u0647\u0631 \u064a\u0648\u0646\u064a\u0648 2026</a>\u060c \u0646\u064f\u0634\u0631 \u0641\u064a 1 \u064a\u0648\u0644\u064a\u0648 2026.</p>"
}
