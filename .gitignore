# バイナリファイルを無視
*.env
*.ini
!alembic.ini
*.service
*.sock
*.exe
*.dll
*.json
!locales/*.json
!locales/**/*.json
!static/manifest.json
!static/manifest_group.json
!static/manifest_note.json
*.Identifier
# ログファイルを無視

*.cgi
*.htaccess

*.zip
*.pptx
*.txt
!ads.txt
!robots.txt
!requirements.txt

# Test files
test_app.py


# OSやIDEの一時ファイルを無視
.DS_Store
Thumbs.db
.vscode/


# .gitkeepのみ追跡対象にする
static/qrcode/*
!static/qrcode/.gitkeep
static/upload/*
!static/upload/.gitkeep
static/group_uploads/*
!static/group_uploads/.gitkeep

storage/*
!storage/.gitkeep

logs/*

geoip/*
!geoip/.gitkeep




# ビルドディレクトリを無視
/build/
.coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/
.venv/
tmp/
__pycache__/.env
__pycache__/
*.pyc
